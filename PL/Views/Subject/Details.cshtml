@model Core.Entities.Subject
@using Core.Entities
@using Core.DTOs.Documents
@{
    ViewData["Title"] = $"{Model.SubjectCode} - Details";
    var userRole = (UserRole)ViewBag.UserRole;
    var documents = (IReadOnlyList<DocumentDto>)ViewBag.Documents;
}

<style>
    .details-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 2rem;
    }
    .subject-info-card {
        background: #fdfdfd;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }
    .upload-box {
        border: 2px dashed #cbd5e1;
        background: #f8fafc;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .upload-box:hover {
        border-color: #6366f1;
        background: #f1f5f9;
    }
    .document-table {
        width: 100%;
        margin-top: 1rem;
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }
    .document-table th {
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid #e2e8f0;
    }
    .document-row {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        transition: transform 0.15s ease;
    }
    .document-row td {
        padding: 1rem;
        vertical-align: middle;
        border-top: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
    }
    .document-row td:first-child {
        border-left: 1px solid #e2e8f0;
        border-top-left-radius: 10px;
        border-bottom-left-radius: 10px;
    }
    .document-row td:last-child {
        border-right: 1px solid #e2e8f0;
        border-top-right-radius: 10px;
        border-bottom-right-radius: 10px;
    }
    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
    }
    .status-Pending { background: #fef3c7; color: #d97706; }
    .status-Processing { background: #ffedd5; color: #ea580c; }
    .status-Success { background: #dcfce7; color: #15803d; }
    .status-Failed { background: #fee2e2; color: #b91c1c; }
</style>

<div class="container py-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Subjects</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show document-alert mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show document-alert mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="details-grid">
        <!-- Main Document Area -->
        <div>
            <div class="subject-info-card">
                <span class="badge bg-primary mb-2">@Model.SubjectCode</span>
                <h1 class="fw-bold" style="color: #1e293b;">@Model.Name</h1>
                <p class="text-muted mt-2">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                <div class="text-secondary mt-3 fs-6">
                    Lecturer: <strong>@(Model.Lecturer != null ? Model.Lecturer.FullName : "Unassigned")</strong>
                </div>
            </div>

            <h3 class="fw-bold mb-3" style="color: #0f172a;">Course Documents</h3>

            @if (!documents.Any())
            {
                <div class="card text-center p-5 border-dashed" style="border: 2px dashed #cbd5e1; border-radius: 12px; background: #fafafa;">
                    <div class="my-3">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                    <h5 class="fw-bold" style="color: #64748b;">No documents uploaded yet</h5>
                    <p class="text-muted">Use the panel on the right to upload files for students to learn.</p>
                </div>
            }
            else
            {
                <table class="document-table">
                    <thead>
                        <tr>
                            <th>File Name</th>
                            <th>Uploaded At</th>
                            <th>AI Indexing Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in documents)
                        {
                            <tr class="document-row">
                                <td>
                                    <div class="fw-bold text-dark text-truncate" style="max-width: 320px;">
                                        <a href="@doc.FileUrl" target="_blank" class="text-decoration-none text-dark hover:text-primary">
                                            @doc.FileName
                                        </a>
                                    </div>
                                </td>
                                <td class="text-muted" style="font-size: 0.875rem;">
                                    @doc.CreatedAt.ToLocalTime().ToString("g")
                                </td>
                                <td>
                                    <span class="status-badge status-@doc.Status.ToString()">
                                        @doc.Status.ToString()
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        @if (doc.Status == DocumentStatus.Failed)
                                        {
                                            <form asp-controller="Document" asp-action="RetryProcessing" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@doc.Id" />
                                                <input type="hidden" name="subjectId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary py-1 px-2.5">
                                                    Retry
                                                </button>
                                            </form>
                                        }
                                        <form asp-controller="Document" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this document?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@doc.Id" />
                                            <input type="hidden" name="subjectId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2.5">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Sidebar Upload Area -->
        <div>
            <div class="card shadow-sm border-0" style="border-radius: 12px; position: sticky; top: 1.5rem;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3" style="color: #1e293b;">Upload Document</h4>
                    <p class="text-muted small mb-4">Supported file formats: PDF, DOCX, DOC, PPTX, PPT, TXT, CSV, MD. Max file size: 50MB.</p>

                    <form asp-controller="Document" asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SubjectId" value="@Model.Id" />

                        <label class="upload-box w-100" id="dropzone" for="fileInput">
                            <svg class="mx-auto mb-2 text-secondary" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="17 8 12 3 7 8"></polyline>
                                <line x1="12" y1="3" x2="12" y2="15"></line>
                            </svg>
                            <span class="d-block fw-semibold" style="color: #475569;" id="upload-label">Choose source file</span>
                            <input id="fileInput" name="File" type="file" class="d-none" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.csv,.md" required />
                        </label>

                        <div id="file-info" class="mt-3 p-2 bg-light border rounded text-truncate" style="display: none; font-size: 0.85rem;">
                            Selected: <strong id="file-name-text"></strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-4 py-2 fw-semibold" style="border-radius: 8px; background: #4f46e5; border-color: #4f46e5;">
                            Upload to Supabase & Index
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('file-info');
        const fileNameText = document.getElementById('file-name-text');
        const uploadLabel = document.getElementById('upload-label');

        fileInput.addEventListener('change', () => {
            const file = fileInput.files?.[0];
            if (file) {
                fileInfo.style.display = 'block';
                fileNameText.textContent = file.name;
                uploadLabel.textContent = 'Change file';
            } else {
                fileInfo.style.display = 'none';
                uploadLabel.textContent = 'Choose source file';
            }
        });
    </script>
}
