@model Core.DTOs.Subject.SubjectDto
@using Core.Entities
@using Core.DTOs.Documents
@{
    ViewData["Title"] = $"{Model.SubjectCode} - Chi tiết";
    var userRole = (UserRole)ViewBag.UserRole;
    var documents = (IReadOnlyList<DocumentDto>)ViewBag.Documents ?? new List<DocumentDto>();
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canUpload = userRole == UserRole.Admin || (userRole == UserRole.Lecturer && Model.LecturerId.ToString() == currentUserId);
}

@functions {
    public static string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 Bytes";
        string[] suffixes = { "Bytes", "KB", "MB", "GB" };
        int counter = 0;
        double number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number = number / 1024;
            counter++;
            if (counter >= suffixes.Length - 1) break;
        }
        return $"{number:F1} {suffixes[counter]}";
    }
}

<!-- Back Link -->
<div class="mb-4">
    @{
        string backAction = userRole == UserRole.Admin ? "Index" : 
                            userRole == UserRole.Lecturer ? "MySubjects" : 
                            "Browse";
    }
    <a asp-action="@backAction" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-on-surface text-sm transition-colors">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        Quay lại danh sách
    </a>
</div>

<div class="space-y-6">
    
    <!-- Subject Overview Card -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6">
        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-1 rounded-lg text-xs font-mono font-bold tracking-tight select-none">
            @Model.SubjectCode
        </span>
        <h1 class="font-headline-lg text-headline-lg font-bold text-on-surface mt-3">@Model.Name</h1>
        <p class="font-body-md text-body-md text-on-surface-variant mt-2 leading-relaxed">
            @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả chi tiết cho môn học này." : Model.Description)
        </p>
        <div class="mt-4 border-t border-outline-variant/30 pt-3 flex items-center gap-2 text-xs text-on-surface-variant select-none">
            <span class="material-symbols-outlined text-[16px]">person</span>
            <span>Giảng viên phụ trách: <strong class="text-on-surface">@(Model.LecturerName ?? "Chưa phân công")</strong></span>
        </div>
    </div>

    <!-- Documents Section -->
    <div>
        <div class="flex justify-between items-center mb-6 select-none">
            <div class="flex items-center gap-3">
                <h3 class="font-headline-sm text-headline-sm font-bold text-on-surface">Tài liệu học tập</h3>
                <span class="bg-surface-container border border-outline-variant/50 px-2.5 py-0.5 rounded-full text-xs text-on-surface-variant">
                    @documents.Count tài liệu
                </span>
            </div>

            @if (canUpload)
            {
                <button onclick="triggerUploadSelection()" class="inline-flex items-center gap-2 bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed font-label-md text-label-md px-5 py-2.5 rounded-xl transition-all duration-150 font-semibold shadow-md hover:scale-[1.01] cursor-pointer border-0">
                    <span class="material-symbols-outlined text-[20px]">cloud_upload</span>
                    Tải lên tài liệu
                </button>
            }
        </div>

        @if (!documents.Any())
        {
            <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant">
                    <span class="material-symbols-outlined text-[36px]">picture_as_pdf</span>
                </div>
                <h5 class="font-headline-sm text-headline-sm text-on-surface mb-1 font-bold">Chưa có tài liệu nào</h5>
                @if (canUpload)
                {
                    <p class="text-on-surface-variant max-w-xs text-xs">Hãy nhấn vào nút "Tải lên tài liệu" phía trên hoặc kéo thả tệp trực tiếp vào trang này để tải lên học liệu.</p>
                }
                else
                {
                    <p class="text-on-surface-variant max-w-xs text-xs">Giảng viên chưa tải lên tài liệu học tập nào cho môn học này.</p>
                }
            </div>
        }
        else
        {
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl overflow-hidden shadow-sm">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-lowest border-b border-outline-variant/50 select-none">
                                <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Tên tài liệu</th>
                                <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider hidden sm:table-cell">Ngày tải lên</th>
                                <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider hidden sm:table-cell">Dung lượng</th>
                                <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                                <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant w-36 text-right pr-6">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/30">
                            @foreach (var doc in documents)
                            {
                                var fileExtension = System.IO.Path.GetExtension(doc.FileName).ToLower().TrimStart('.');
                                var iconName = fileExtension switch
                                {
                                    "pdf" => "picture_as_pdf",
                                    "docx" or "doc" => "description",
                                    "pptx" or "ppt" => "slideshow",
                                    "xlsx" or "xls" => "table_chart",
                                    _ => "text_snippet"
                                };
                                var iconColorClass = fileExtension switch
                                {
                                    "pdf" => "text-error",
                                    "docx" or "doc" => "text-primary",
                                    "pptx" or "ppt" => "text-secondary",
                                    "xlsx" or "xls" => "text-tertiary",
                                    _ => "text-outline"
                                };

                                <tr class="hover:bg-surface-container/30 transition-colors group">
                                    <td class="p-4 align-middle">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded bg-surface-container flex items-center justify-center flex-shrink-0 @iconColorClass border border-outline-variant/20 select-none">
                                                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">@iconName</span>
                                            </div>
                                            <div class="min-w-0">
                                                <a asp-controller="Document" asp-action="Details" asp-route-id="@doc.Id" class="font-body-md text-body-md font-medium text-on-surface truncate hover:text-primary transition-colors max-w-[200px] sm:max-w-xs block" title="@doc.FileName">
                                                    @doc.FileName
                                                </a>
                                                <div class="flex items-center gap-1.5 mt-0.5 text-[10px] text-outline sm:hidden select-none">
                                                    <span>@doc.CreatedAt.ToLocalTime().ToString("g")</span>
                                                    <span>&bull;</span>
                                                    <span>@FormatFileSize(doc.FileSize)</span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-4 align-middle hidden sm:table-cell font-body-md text-body-md text-on-surface-variant select-none">
                                        @doc.CreatedAt.ToLocalTime().ToString("g")
                                    </td>
                                    <td class="p-4 align-middle hidden sm:table-cell font-body-md text-body-md text-on-surface-variant select-none">
                                        @FormatFileSize(doc.FileSize)
                                    </td>
                                    <td class="p-4 align-middle select-none">
                                        @{
                                            var badgeColorClass = doc.Status switch
                                            {
                                                DocumentStatus.Success => "bg-tertiary-container/20 border-tertiary/20 text-tertiary",
                                                DocumentStatus.Failed => "bg-error-container/20 border-error/20 text-error",
                                                DocumentStatus.Processing => "bg-blue-500/10 border-blue-500/20 text-blue-500",
                                                _ => "bg-yellow-500/10 border-yellow-500/20 text-yellow-500"
                                            };
                                        }
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full border text-[11px] font-semibold @badgeColorClass">
                                            @if (doc.Status == DocumentStatus.Processing)
                                            {
                                                <span class="w-3 h-3 border-2 border-t-transparent border-blue-500 rounded-full animate-spin"></span>
                                            }
                                            else
                                            {
                                                <span class="w-1.5 h-1.5 rounded-full @(doc.Status == DocumentStatus.Success ? "bg-tertiary" : doc.Status == DocumentStatus.Failed ? "bg-error" : "bg-yellow-500")"></span>
                                            }
                                            @doc.Status.ToString()
                                        </span>
                                    </td>
                                    <td class="p-4 align-middle text-right pr-6 w-36">
                                        <div class="inline-flex justify-end gap-2 items-center">
                                            @if (doc.Status == DocumentStatus.Failed)
                                            {
                                                <form asp-controller="Document" asp-action="RetryProcessing" method="post" class="inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="subjectId" value="@Model.Id" />
                                                    <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-primary transition-colors cursor-pointer" title="Thử lại AI indexing">
                                                        <span class="material-symbols-outlined text-[16px]">refresh</span>
                                                    </button>
                                                </form>
                                            }
                                            <a asp-controller="Document" asp-action="Details" asp-route-id="@doc.Id" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-on-surface-variant transition-colors" title="Xem danh sách chunks">
                                                <span class="material-symbols-outlined text-[16px]">list</span>
                                            </a>
                                            
                                            @if (canUpload)
                                            {
                                                <form asp-controller="Document" asp-action="Delete" method="post" class="inline" data-confirm="Bạn có chắc chắn muốn xóa tài liệu này?">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="subjectId" value="@Model.Id" />
                                                    <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-error-container/20 rounded text-error transition-colors cursor-pointer" title="Xóa tài liệu">
                                                        <span class="material-symbols-outlined text-[16px]">delete</span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@if (canUpload)
{
    <!-- Page Drag & Drop Overlay -->
    <div id="dragDropPageOverlay" class="fixed inset-0 z-[20000] bg-background/85 backdrop-blur-md flex flex-col items-center justify-center border-4 border-dashed border-primary/40 m-4 rounded-2xl pointer-events-none opacity-0 transition-opacity duration-300">
        <div class="flex flex-col items-center text-center p-6 select-none animate-bounce pointer-events-none">
            <div class="w-20 h-20 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center text-primary mb-4">
                <span class="material-symbols-outlined text-[48px]">cloud_upload</span>
            </div>
            <h3 class="font-headline-md text-headline-md font-bold text-on-surface mb-2">Thả tài liệu vào đây</h3>
            <p class="text-xs text-on-surface-variant max-w-xs">Hỗ trợ tải lên một hoặc nhiều tệp cùng lúc cho môn học này.</p>
        </div>
    </div>

    <!-- Direct File Upload Form (Hidden) -->
    <form asp-controller="Document" asp-action="Upload" method="post" enctype="multipart/form-data" id="directUploadForm" class="hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SubjectId" value="@Model.Id" />
        <input id="directFileInput" name="Files" type="file" class="hidden" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.csv,.md" multiple required />
    </form>
}

@section Scripts {
    @if (canUpload)
    {
        <script>
            const pageOverlay = document.getElementById('dragDropPageOverlay');
            const directFileInput = document.getElementById('directFileInput');
            const directUploadForm = document.getElementById('directUploadForm');

            function triggerUploadSelection() {
                if (directFileInput) {
                    directFileInput.click();
                }
            }

            if (directFileInput && directUploadForm) {
                directFileInput.addEventListener('change', () => {
                    if (directFileInput.files && directFileInput.files.length > 0) {
                        showNotification('Đang tải tài liệu lên...', 'info');
                        directUploadForm.submit();
                    }
                });
            }

            // Page-wide Drag & Drop Overlay triggers with dragCounter to prevent flickering
            let dragCounter = 0;

            window.addEventListener('dragenter', (e) => {
                if (e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
                    e.preventDefault();
                    dragCounter++;
                    if (dragCounter === 1) {
                        pageOverlay.classList.remove('opacity-0', 'pointer-events-none');
                        pageOverlay.classList.add('opacity-100');
                    }
                }
            });

            window.addEventListener('dragover', (e) => {
                if (e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
                    e.preventDefault();
                }
            });

            window.addEventListener('dragleave', (e) => {
                if (e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
                    e.preventDefault();
                    dragCounter--;
                    if (dragCounter <= 0) {
                        dragCounter = 0;
                        pageOverlay.classList.add('opacity-0', 'pointer-events-none');
                        pageOverlay.classList.remove('opacity-100');
                    }
                }
            });

            window.addEventListener('drop', (e) => {
                if (e.dataTransfer.types && e.dataTransfer.types.includes('Files')) {
                    e.preventDefault();
                    dragCounter = 0;
                    pageOverlay.classList.add('opacity-0', 'pointer-events-none');
                    pageOverlay.classList.remove('opacity-100');
                    
                    const files = e.dataTransfer.files;
                    if (files && files.length > 0 && directFileInput && directUploadForm) {
                        showNotification('Đang tải tài liệu lên...', 'info');
                        directFileInput.files = files;
                        directUploadForm.submit();
                    }
                }
            });

            ['dragend', 'dragexit'].forEach(eventName => {
                window.addEventListener(eventName, (e) => {
                    dragCounter = 0;
                    pageOverlay.classList.add('opacity-0', 'pointer-events-none');
                    pageOverlay.classList.remove('opacity-100');
                });
            });
        </script>
    }
}
