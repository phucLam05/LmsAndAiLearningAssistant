@model IEnumerable<Core.DTOs.Subject.SubjectDto>
@using Core.Entities
@{
    ViewData["Title"] = "Môn học";
    var userRole = (UserRole)ViewBag.UserRole;
    var totalSubjects = Model.Count();
    var activeSubjects = Model.Count(s => s.Status == SubjectStatus.Active);
}



<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface tracking-tight">Môn học</h1>
        @if (userRole == UserRole.Admin)
        {
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Quản lý danh sách môn học, giảng viên và thiết lập cấu hình.</p>
        }
        else if (userRole == UserRole.Lecturer)
        {
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Danh sách môn học bạn được phân công giảng dạy.</p>
        }
        else
        {
            <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Chọn môn học để bắt đầu học tập và hỏi đáp với Trợ lý AI.</p>
        }
    </div>
    @if (userRole == UserRole.Admin)
    {
        <button id="openCreateModalBtn" class="bg-primary text-on-primary font-label-md text-label-md px-5 py-2.5 rounded-full hover:bg-primary-fixed hover:text-on-primary-fixed transition-all duration-200 flex items-center gap-2 font-medium shadow-sm hover:scale-[1.02] cursor-pointer">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Tạo môn học mới
        </button>
    }
</div>

<!-- Stats Bento Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <!-- Stat 1 -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group select-none">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="material-symbols-outlined text-[64px] text-primary">folder</span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Tổng số môn học</p>
        <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@totalSubjects</h3>
        <p class="font-label-md text-label-md text-outline mt-3">Đăng ký trong hệ thống</p>
    </div>
    <!-- Stat 2 -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group select-none">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="material-symbols-outlined text-[64px] text-tertiary">task_alt</span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Đang hoạt động</p>
        <h3 class="font-headline-lg text-headline-lg font-bold text-on-surface">@activeSubjects</h3>
        <p class="font-label-md text-label-md text-outline mt-3">Sẵn sàng để học tập</p>
    </div>
    <!-- Stat 3 -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-5 relative overflow-hidden group select-none">
        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
            <span class="material-symbols-outlined text-[64px] text-secondary">shield</span>
        </div>
        <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-1">Vai trò của bạn</p>
        <h3 class="font-headline-lg text-headline-lg font-bold text-secondary">
            @(userRole == UserRole.Admin ? "Quản trị viên" : userRole == UserRole.Lecturer ? "Giảng viên" : "Sinh viên")
        </h3>
        <p class="font-label-md text-label-md text-outline mt-3">Quyền truy cập tài nguyên</p>
    </div>
</div>

<!-- Subject List Workspace -->
@if (!Model.Any())
{
    <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center my-6">
        <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant">
            <span class="material-symbols-outlined text-[36px]">folder_off</span>
        </div>
        <h3 class="font-headline-sm text-headline-sm font-semibold text-on-surface mb-2">Chưa có môn học nào</h3>
        <p class="text-on-surface-variant max-w-sm text-sm">Không tìm thấy môn học nào đang được đăng ký trên hệ thống của bạn.</p>
    </div>
}
else
{
    @if (userRole == UserRole.Student || userRole == UserRole.Lecturer)
    {
        <div class="mb-6 flex justify-end">
            <div class="w-full max-w-sm">
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-outline transition-colors group-focus-within:text-primary">search</span>
                    </div>
                    <input id="subjectSearchInput" type="text"
                           class="w-full bg-surface-container-low border border-outline-variant/60 text-on-surface font-body-md text-body-md rounded-xl pl-12 pr-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-all placeholder:text-outline/50 shadow-sm"
                           placeholder="Tìm kiếm môn học..." />
                </div>
                <p id="subjectSearchNoResult" class="hidden mt-3 text-on-surface-variant text-sm text-right">Không tìm thấy môn học nào phù hợp.</p>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="subjectGrid">
        @foreach (var subject in Model)
        {
            <div class="bg-surface-container-low border border-outline-variant/50 rounded-xl p-5 hover:border-outline-variant hover:bg-surface-container transition-all group flex flex-col justify-between relative shadow-sm subject-card" data-search="@(subject.Name?.ToLower()) @(subject.SubjectCode?.ToLower()) @(subject.LecturerName?.ToLower())">
                <div>
                    <!-- Code and Status Header -->
                    <div class="flex justify-between items-center mb-4">
                        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-1 rounded-lg text-xs font-mono font-bold tracking-tight select-none">
                            @subject.SubjectCode
                        </span>
                        
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full border text-[11px] font-semibold select-none @(subject.Status == SubjectStatus.Active ? "bg-tertiary-container/20 border-tertiary/20 text-tertiary" : "bg-error-container/20 border-error/20 text-error")">
                            <span class="w-1.5 h-1.5 rounded-full @(subject.Status == SubjectStatus.Active ? "bg-tertiary animate-pulse" : "bg-error")"></span>
                            @(subject.Status == SubjectStatus.Active ? "Active" : "Inactive")
                        </span>
                    </div>

                    <!-- Title & Desc -->
                    <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2 font-bold group-hover:text-primary transition-colors truncate" title="@subject.Name">
                        @subject.Name
                    </h3>
                    <p class="font-body-md text-body-md text-on-surface-variant/80 mb-5 line-clamp-3 min-h-[60px] leading-relaxed">
                        @(string.IsNullOrEmpty(subject.Description) ? "Môn học này hiện chưa được cập nhật mô tả chi tiết." : subject.Description)
                    </p>
                </div>

                <!-- Footer details & actions -->
                <div class="mt-auto border-t border-outline-variant/30 pt-4">
                    <!-- Lecturer identity -->
                    <div class="flex items-center gap-2 text-on-surface-variant mb-4 select-none">
                        <span class="material-symbols-outlined text-[18px]">person</span>
                        <span class="text-xs">Giảng viên: <strong class="text-on-surface">@(!string.IsNullOrEmpty(subject.LecturerName) ? subject.LecturerName : "Chưa phân công")</strong></span>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-2">
                        @if (userRole == UserRole.Admin)
                        {
                            <button type="button" 
                                    class="open-edit-modal-btn flex-1 text-center bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface py-2 rounded-lg font-label-md text-label-md transition-colors flex items-center justify-center gap-1 cursor-pointer"
                                    data-id="@subject.Id"
                                    data-code="@subject.SubjectCode"
                                    data-name="@subject.Name"
                                    data-desc="@subject.Description"
                                    data-lecturer="@subject.LecturerId"
                                    data-status="@((int)subject.Status)">
                                <span class="material-symbols-outlined text-[16px]">edit</span>
                                Sửa
                            </button>
                            <a asp-action="Details" asp-route-id="@subject.Id" class="flex-1 text-center bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed py-2 rounded-lg font-label-md text-label-md transition-colors flex items-center justify-center gap-1 font-medium">
                                <span class="material-symbols-outlined text-[16px]">database</span>
                                Tài liệu
                            </a>
                            <form asp-action="Delete" asp-route-id="@subject.Id" method="post" class="inline-flex" data-confirm="Bạn có chắc chắn muốn xóa môn học này? Tất cả tài liệu liên quan sẽ bị xóa vĩnh viễn.">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="bg-error-container/20 border border-error/30 text-error hover:bg-error-container/40 p-2 rounded-lg transition-colors flex items-center justify-center" title="Xóa môn học">
                                    <span class="material-symbols-outlined text-[16px]">delete</span>
                                </button>
                            </form>
                        }
                        else if (userRole == UserRole.Lecturer)
                        {
                            <a asp-action="Details" asp-route-id="@subject.Id" class="w-full text-center bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed py-2.5 rounded-lg font-label-md text-label-md transition-colors flex items-center justify-center gap-2 font-semibold shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">cloud_upload</span>
                                Quản lý tài liệu & upload
                            </a>
                        }
                        else // Student
                        {
                            <a asp-action="Chat" asp-route-subjectId="@subject.Id" class="w-full text-center bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed py-2.5 rounded-lg font-label-md text-label-md transition-colors flex items-center justify-center gap-2 font-semibold shadow-sm hover:scale-[1.01]">
                                <span class="material-symbols-outlined text-[18px] filled">smart_toy</span>
                                Học với Trợ lý AI
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (userRole == UserRole.Admin)
{
    <!-- Creation Modal (Popup) -->
    <div id="createSubjectModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm hidden transition-all duration-300">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 md:p-8 max-w-lg w-full shadow-2xl relative select-none transform scale-95 opacity-0 transition-all duration-300" id="createSubjectModalCard">
            
            <!-- Close Button -->
            <button id="closeCreateModalBtn" class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high p-1.5 rounded-lg transition-colors cursor-pointer" title="Đóng">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>

            <h2 class="font-headline-md text-headline-md font-bold text-on-surface mb-2">Tạo môn học mới</h2>
            <p class="font-body-md text-xs text-on-surface-variant mb-6 leading-relaxed">Đăng ký một môn học mới trên hệ thống và phân công giảng viên phụ trách môn học.</p>

            <form id="createSubjectForm" class="space-y-4">
                @Html.AntiForgeryToken()
                
                <div id="modalErrorAlert" class="bg-error-container/20 border border-error-container/30 text-error p-3 rounded-xl text-xs flex items-start gap-2 mb-4 hidden">
                    <span class="material-symbols-outlined text-[18px]">error</span>
                    <span id="modalErrorAlertText">Vui lòng kiểm tra lại dữ liệu nhập vào.</span>
                </div>

                <div class="space-y-1">
                    <label for="subjectCode" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Mã môn học</label>
                    <input type="text" name="subjectCode" id="subjectCode" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. PRN222" required />
                    <span class="text-[10px] text-outline block">Mã môn học phải là duy nhất (ví dụ: INT101, PRN211, v.v.).</span>
                </div>

                <div class="space-y-1">
                    <label for="name" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Tên môn học</label>
                    <input type="text" name="name" id="name" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. Web Application Development" required />
                </div>

                <div class="space-y-1">
                    <label for="description" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Mô tả chi tiết</label>
                    <textarea name="description" id="description" rows="3" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="Mô tả ngắn gọn về chương trình học và nội dung môn học..."></textarea>
                </div>

                <div class="space-y-1">
                    <label for="lecturerId" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Phân công Giảng viên</label>
                    <select name="lecturerId" id="lecturerId" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" asp-items="ViewBag.Lecturers">
                        <option value="">-- Chọn Giảng viên phụ trách (Không bắt buộc) --</option>
                    </select>
                    <span class="text-[10px] text-outline block">Mỗi môn học chỉ gán cho tối đa một giảng viên quản lý.</span>
                </div>

                <div class="flex items-center justify-end gap-3 pt-4 border-t border-outline-variant/30 mt-6">
                    <button type="button" id="cancelCreateModalBtn" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl text-xs font-semibold transition-colors cursor-pointer">
                        Hủy
                    </button>
                    <button type="submit" class="bg-primary hover:bg-primary/95 text-on-primary font-bold py-2.5 px-5 rounded-xl shadow-md transition-all duration-200 flex items-center justify-center gap-2 text-xs font-semibold hover:scale-[1.01] cursor-pointer">
                        <span>Tạo môn học</span>
                        <span class="material-symbols-outlined text-[16px]">add</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal (Popup) -->
    <div id="editSubjectModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm hidden transition-all duration-300">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 md:p-8 max-w-lg w-full shadow-2xl relative select-none transform scale-95 opacity-0 transition-all duration-300" id="editSubjectModalCard">
            
            <!-- Close Button -->
            <button id="closeEditModalBtn" class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high p-1.5 rounded-lg transition-colors cursor-pointer" title="Đóng">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>

            <h2 class="font-headline-md text-headline-md font-bold text-on-surface mb-2">Chỉnh sửa môn học</h2>
            <p class="font-body-md text-xs text-on-surface-variant mb-6 leading-relaxed">Thay đổi thông tin môn học, thiết lập trạng thái hoạt động hoặc phân công lại giảng viên.</p>

            <form id="editSubjectForm" class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editSubjectId" />

                <div id="editModalErrorAlert" class="bg-error-container/20 border border-error-container/30 text-error p-3 rounded-xl text-xs flex items-start gap-2 mb-4 hidden">
                    <span class="material-symbols-outlined text-[18px]">error</span>
                    <span id="editModalErrorAlertText">Vui lòng kiểm tra lại thông tin nhập vào.</span>
                </div>

                <div class="space-y-1">
                    <label for="editSubjectCode" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Mã môn học</label>
                    <input type="text" id="editSubjectCode" class="bg-surface-container-lowest/50 border border-outline-variant/40 rounded-xl px-4 py-3 text-on-surface-variant/70 focus:outline-none w-full text-xs transition-all cursor-not-allowed" disabled />
                </div>

                <div class="space-y-1">
                    <label for="editName" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Tên môn học</label>
                    <input type="text" name="name" id="editName" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. Web Application Development" required />
                </div>

                <div class="space-y-1">
                    <label for="editDescription" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Mô tả môn học</label>
                    <textarea name="description" id="editDescription" rows="3" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="Mô tả tóm tắt nội dung môn học..."></textarea>
                </div>

                <div class="space-y-1">
                    <label for="editLecturerId" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Giảng viên phụ trách</label>
                    <select name="lecturerId" id="editLecturerId" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" asp-items="ViewBag.Lecturers">
                        <option value="">-- Chọn Giảng viên phụ trách --</option>
                    </select>
                </div>

                <div class="space-y-1">
                    <label for="editStatus" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Trạng thái</label>
                    <select name="status" id="editStatus" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all">
                        <option value="@((int)SubjectStatus.Active)">Đang hoạt động (Active)</option>
                        <option value="@((int)SubjectStatus.Inactive)">Ngừng hoạt động (Inactive)</option>
                    </select>
                </div>

                <div class="flex items-center justify-end gap-3 pt-4 border-t border-outline-variant/30 mt-6">
                    <button type="button" id="cancelEditModalBtn" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-5 py-2.5 rounded-xl text-xs font-semibold transition-colors cursor-pointer">
                        Hủy
                    </button>
                    <button type="submit" class="bg-primary hover:bg-primary/95 text-on-primary font-bold py-2.5 px-5 rounded-xl shadow-md transition-all duration-200 flex items-center justify-center gap-2 text-xs font-semibold hover:scale-[1.01] cursor-pointer">
                        <span>Lưu thay đổi</span>
                        <span class="material-symbols-outlined text-[16px]">save</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    @if (userRole == UserRole.Admin)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Create Modal Logic
                const openBtn = document.getElementById('openCreateModalBtn');
                const modal = document.getElementById('createSubjectModal');
                const card = document.getElementById('createSubjectModalCard');
                const closeBtn = document.getElementById('closeCreateModalBtn');
                const cancelBtn = document.getElementById('cancelCreateModalBtn');
                const form = document.getElementById('createSubjectForm');
                const errorAlert = document.getElementById('modalErrorAlert');
                const errorAlertText = document.getElementById('modalErrorAlertText');

                function openModal() {
                    modal.classList.remove('hidden');
                    void card.offsetWidth;
                    card.classList.remove('scale-95', 'opacity-0');
                    card.classList.add('scale-100', 'opacity-100');
                    document.body.style.overflow = 'hidden';
                }

                function closeModal() {
                    card.classList.remove('scale-100', 'opacity-100');
                    card.classList.add('scale-95', 'opacity-0');
                    setTimeout(() => {
                        modal.classList.add('hidden');
                        form.reset();
                        errorAlert.classList.add('hidden');
                        document.body.style.overflow = '';
                    }, 300);
                }

                if (openBtn) openBtn.addEventListener('click', openModal);
                if (closeBtn) closeBtn.addEventListener('click', closeModal);
                if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

                modal.addEventListener('click', function (e) {
                    if (e.target === modal) {
                        closeModal();
                    }
                });

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                        closeModal();
                    }
                });

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    errorAlert.classList.add('hidden');

                    const formData = new FormData(form);

                    fetch('/Subject/Create', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Mạng gặp sự cố hoặc máy chủ phản hồi lỗi.');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            window.location.reload();
                        } else {
                            errorAlertText.textContent = data.error || 'Vui lòng kiểm tra lại dữ liệu nhập vào.';
                            errorAlert.classList.remove('hidden');
                        }
                    })
                    .catch(err => {
                        errorAlertText.textContent = err.message || 'Lỗi kết nối. Vui lòng thử lại sau.';
                        errorAlert.classList.remove('hidden');
                    });
                });

                // Edit Modal Logic
                const editModal = document.getElementById('editSubjectModal');
                const editCard = document.getElementById('editSubjectModalCard');
                const closeEditBtn = document.getElementById('closeEditModalBtn');
                const cancelEditBtn = document.getElementById('cancelEditModalBtn');
                const editForm = document.getElementById('editSubjectForm');
                const editErrorAlert = document.getElementById('editModalErrorAlert');
                const editErrorAlertText = document.getElementById('editModalErrorAlertText');
                
                // Form Inputs
                const editIdInput = document.getElementById('editSubjectId');
                const editCodeInput = document.getElementById('editSubjectCode');
                const editNameInput = document.getElementById('editName');
                const editDescInput = document.getElementById('editDescription');
                const editLecturerInput = document.getElementById('editLecturerId');
                const editStatusInput = document.getElementById('editStatus');

                function openEditModal(btn) {
                    editIdInput.value = btn.getAttribute('data-id') || '';
                    editCodeInput.value = btn.getAttribute('data-code') || '';
                    editNameInput.value = btn.getAttribute('data-name') || '';
                    editDescInput.value = btn.getAttribute('data-desc') || '';
                    editLecturerInput.value = btn.getAttribute('data-lecturer') || '';
                    editStatusInput.value = btn.getAttribute('data-status') || '1';

                    editModal.classList.remove('hidden');
                    void editCard.offsetWidth;
                    editCard.classList.remove('scale-95', 'opacity-0');
                    editCard.classList.add('scale-100', 'opacity-100');
                    document.body.style.overflow = 'hidden';
                }

                function closeEditModal() {
                    editCard.classList.remove('scale-100', 'opacity-100');
                    editCard.classList.add('scale-95', 'opacity-0');
                    setTimeout(() => {
                        editModal.classList.add('hidden');
                        editForm.reset();
                        editErrorAlert.classList.add('hidden');
                        document.body.style.overflow = '';
                    }, 300);
                }

                document.querySelectorAll('.open-edit-modal-btn').forEach(btn => {
                    btn.addEventListener('click', () => openEditModal(btn));
                });

                if (closeEditBtn) closeEditBtn.addEventListener('click', closeEditModal);
                if (cancelEditBtn) cancelEditBtn.addEventListener('click', closeEditModal);

                editModal.addEventListener('click', function (e) {
                    if (e.target === editModal) {
                        closeEditModal();
                    }
                });

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !editModal.classList.contains('hidden')) {
                        closeEditModal();
                    }
                });

                editForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    editErrorAlert.classList.add('hidden');

                    const formData = new FormData(editForm);

                    fetch('/Subject/Edit', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Mạng gặp sự cố hoặc máy chủ phản hồi lỗi.');
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            window.location.reload();
                        } else {
                            editErrorAlertText.textContent = data.error || 'Vui lòng kiểm tra lại thông tin nhập vào.';
                            editErrorAlert.classList.remove('hidden');
                        }
                    })
                    .catch(err => {
                        editErrorAlertText.textContent = err.message || 'Lỗi kết nối. Vui lòng thử lại sau.';
                        editErrorAlert.classList.remove('hidden');
                    });
                });
            });
        </script>
    }

    @if (userRole == UserRole.Student || userRole == UserRole.Lecturer)
    {
        <script>
            (function() {
                const searchInput = document.getElementById('subjectSearchInput');
                const noResult = document.getElementById('subjectSearchNoResult');
                if (!searchInput) return;

                searchInput.addEventListener('input', function() {
                    const q = this.value.trim().toLowerCase();
                    const cards = document.querySelectorAll('.subject-card');
                    let visibleCount = 0;

                    cards.forEach(card => {
                        const text = (card.getAttribute('data-search') || '').toLowerCase();
                        const visible = !q || text.includes(q);
                        card.style.display = visible ? '' : 'none';
                        if (visible) visibleCount++;
                    });

                    if (noResult) {
                        noResult.classList.toggle('hidden', visibleCount > 0 || !q);
                    }
                });
            })();
        </script>
    }
}
