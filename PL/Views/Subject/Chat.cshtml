@model Core.DTOs.Subject.SubjectDto
@using Core.Entities
@inject BLL.Interfaces.IDocumentService DocumentService
@{
    ViewData["Title"] = $"{Model.SubjectCode} - Trợ lý AI";
    var docs = await DocumentService.GetDocumentsBySubjectIdAsync(Model.Id);
}

@functions {
    public static string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 Bytes";
        string[] suffixes = { "Bytes", "KB", "MB", "GB" };
        int counter = 0;
        double number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number = number / 1024;
            counter++;
            if (counter >= suffixes.Length - 1) break;
        }
        return $"{number:F1} {suffixes[counter]}";
    }
}

<div class="h-[calc(100vh-120px)] flex flex-col md:flex-row gap-6 overflow-hidden">
    
    <!-- Left Sidebar: Sources Panel (NotebookLM Inspired) -->
    <aside class="w-full md:w-[280px] bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex flex-col shrink-0 select-none">
        <div class="mb-5">
            @{
                var userRoleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Student";
                Enum.TryParse<UserRole>(userRoleClaim, out var uRole);
                string backAction = uRole == UserRole.Admin ? "Index" : 
                                    uRole == UserRole.Lecturer ? "MySubjects" : 
                                    "Browse";
            }
            <a asp-action="@backAction" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-on-surface text-xs transition-colors mb-4">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                Danh sách môn học
            </a>
            
            <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-xs font-mono font-bold tracking-tight">
                @Model.SubjectCode
            </span>
            <h4 class="font-headline-sm text-headline-sm font-bold text-on-surface mt-2 truncate" title="@Model.Name">@Model.Name</h4>
            <p class="font-body-md text-xs text-on-surface-variant mt-1 leading-relaxed line-clamp-3">
                @(string.IsNullOrEmpty(Model.Description) ? "Môn học chưa được cập nhật mô tả chi tiết." : Model.Description)
            </p>
        </div>

        <!-- Sources Section -->
        <div class="flex-1 flex flex-col min-h-0">
            <div class="flex justify-between items-center mb-3">
                <span class="font-label-md text-label-md uppercase tracking-wider text-outline font-bold text-[10px]">Tài liệu học tập (@docs.Count)</span>
                @if (docs.Any(d => d.Status == DocumentStatus.Success))
                {
                    <button id="toggleSelectAll" onclick="toggleSelectAll()" class="text-[10px] text-primary hover:text-primary-fixed font-semibold transition-colors cursor-pointer select-none">
                        Chọn tất cả
                    </button>
                }
            </div>


            <div class="flex-1 overflow-y-auto space-y-2 pr-1">
                @if (!docs.Any())
                {
                    <div class="text-center py-6 text-on-surface-variant text-xs border border-dashed border-outline-variant/30 rounded-xl bg-surface/20">
                        <span class="material-symbols-outlined text-[24px] text-outline mb-1">description_off</span>
                        <p class="px-3">Chưa có tài liệu học tập nào được upload cho môn học này.</p>
                    </div>
                }
                else
                {
                    @foreach (var doc in docs)
                    {
                        var ext = System.IO.Path.GetExtension(doc.FileName).ToLower().TrimStart('.');
                        var icon = ext switch
                        {
                            "pdf" => "picture_as_pdf",
                            "docx" or "doc" => "description",
                            "pptx" or "ppt" => "slideshow",
                            "xlsx" or "xls" => "table_chart",
                            _ => "text_snippet"
                        };
                        var iconColor = ext switch
                        {
                            "pdf" => "text-error",
                            "docx" or "doc" => "text-primary",
                            "pptx" or "ppt" => "text-secondary",
                            "xlsx" or "xls" => "text-tertiary",
                            _ => "text-outline"
                        };
                        bool isReady = doc.Status == DocumentStatus.Success;

                        <label class="flex items-center gap-2.5 rounded-xl p-2.5 transition-all border select-none @(isReady ? "bg-surface/40 hover:bg-surface border-outline-variant/20 cursor-pointer doc-card" : "bg-surface/10 border-outline-variant/10 opacity-50 cursor-not-allowed")" title="@doc.FileName">
                            <span class="material-symbols-outlined text-[20px] @iconColor flex-shrink-0" style="font-variation-settings: 'FILL' 1;">@icon</span>
                            <div class="min-w-0 flex-1">
                                <span class="text-xs font-semibold text-on-surface truncate block">@doc.FileName</span>
                                <div class="flex items-center gap-1.5 mt-0.5">
                                    <span class="w-1.5 h-1.5 rounded-full @(doc.Status == DocumentStatus.Success ? "bg-tertiary" : doc.Status == DocumentStatus.Failed ? "bg-error" : "bg-yellow-500")"></span>
                                    <span class="text-[9px] text-outline">@(doc.Status == DocumentStatus.Success ? "Đã Index" : doc.Status == DocumentStatus.Failed ? "Failed" : "Đang xử lý")</span>
                                    <span class="text-[9px] text-outline">&bull;</span>
                                    <span class="text-[9px] text-outline">@FormatFileSize(doc.FileSize)</span>
                                </div>
                            </div>
                            @if (isReady)
                            {
                                <input type="checkbox" class="doc-checkbox w-4.5 h-4.5 rounded border border-outline/30 bg-surface-container-high checked:bg-primary checked:border-primary cursor-pointer flex-shrink-0 appearance-none flex items-center justify-center after:content-['✓'] after:text-on-primary after:text-[11px] after:font-black after:hidden checked:after:block focus:outline-none transition-all"
                                       value="@doc.Id" checked onchange="onDocCheckboxChange()" />
                            }
                            else
                            {
                                <span class="w-4.5 h-4.5 flex-shrink-0"></span>
                            }
                        </label>
                    }
                }
            </div>
        </div>

        <div class="border-t border-outline-variant/30 pt-4 mt-4 text-[11px] text-on-surface-variant flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[16px]">person</span>
            <span>Giảng viên: <strong>@(Model.LecturerName ?? "Chưa phân công")</strong></span>
        </div>
    </aside>

    <!-- Right Chat Workspace -->
    <section class="flex-grow bg-surface border border-outline-variant/30 rounded-2xl flex flex-col justify-between overflow-hidden shadow-sm h-full">
        <!-- Messages Area -->
        <div class="flex-1 overflow-y-auto p-5 space-y-4 bg-surface-dim/30" id="chatMessages">
            
            <!-- Welcome Bot Message -->
            <div class="flex flex-col items-start w-full gap-1">
                <div class="flex items-center gap-2 px-1 select-none">
                    <span class="material-symbols-outlined text-tertiary text-[16px] filled">smart_toy</span>
                    <span class="font-label-md text-label-md text-on-surface-variant text-[10px]">Trợ lý Học tập AI</span>
                </div>
                <div class="bg-surface text-on-surface font-body-md text-sm px-4 py-3 rounded-2xl rounded-tl-sm max-w-[85%] border border-outline-variant shadow-sm leading-relaxed">
                    <p>Xin chào! Tôi là Trợ lý Học tập AI của bạn cho môn học <strong>@Model.SubjectCode - @Model.Name</strong>. Tôi đã sẵn sàng để trả lời bất kỳ câu hỏi nào của bạn dựa trên học liệu được upload ở bảng bên trái. Hãy bắt đầu hỏi nhé!</p>
                </div>
            </div>
            
        </div>

        <!-- Input Area sticky bottom -->
        <div class="p-4 bg-surface-container-low border-t border-outline-variant/40">
            <!-- Suggested prompt chips -->
            <div class="flex gap-2 mb-3 overflow-x-auto pb-1 select-none whitespace-nowrap scrollbar-none" style="scrollbar-width: none;">
                <button onclick="setQuery('Tóm tắt tài liệu môn học này')" class="font-label-md text-[11px] px-3.5 py-1.5 rounded-full border border-outline-variant text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest hover:border-outline transition-all duration-150">
                    Tóm tắt tài liệu môn học này
                </button>
                <button onclick="setQuery('Những khái niệm cốt lõi nào cần nắm vững?')" class="font-label-md text-[11px] px-3.5 py-1.5 rounded-full border border-outline-variant text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest hover:border-outline transition-all duration-150">
                    Những khái niệm cốt lõi nào cần nắm vững?
                </button>
                <button onclick="setQuery('Liệt kê tài liệu tham khảo')" class="font-label-md text-[11px] px-3.5 py-1.5 rounded-full border border-outline-variant text-on-surface-variant hover:text-on-surface hover:bg-surface-container-highest hover:border-outline transition-all duration-150">
                    Liệt kê tài liệu tham khảo
                </button>
            </div>

            <!-- Model Selector + Chat Form -->
            <form id="chatForm" class="m-0">
                @Html.AntiForgeryToken()
                <!-- Model Selector Row -->
                <div class="flex items-center justify-between mb-2.5">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[14px] text-outline">psychology</span>
                        <span class="font-label-md text-[10px] text-outline uppercase tracking-wider">Model AI</span>
                    </div>
                    <div class="relative">
                        <select id="modelSelector"
                                class="appearance-none bg-surface-container-highest border border-outline-variant/60 text-on-surface font-body-md text-xs rounded-lg pl-3 pr-7 py-1.5 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary transition-all cursor-pointer">
                            <option value="gemini-2.5-flash" selected>⚡ Gemini 2.5 Flash</option>
                            <option value="gemini-2.5-flash-lite">🪶 Gemini 2.5 Flash Lite</option>
                            <option value="gemini-2.0-flash">🔵 Gemini 2.0 Flash</option>
                            <option value="gemini-3.1-flash-lite">⚡⚡ Gemini 3.1 Flash Lite</option>
                            <option value="gemini-3.5-flash">✨ Gemini 3.5 Flash</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2">
                            <span class="material-symbols-outlined text-[14px] text-outline">expand_more</span>
                        </div>
                    </div>
                </div>

                <div class="relative flex items-end bg-surface-container-highest border border-outline-variant rounded-xl focus-within:ring-1 focus-within:ring-primary focus-within:border-primary transition-all">
                    <button type="button" class="p-3 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center select-none">
                        <span class="material-symbols-outlined text-[20px]">add_circle</span>
                    </button>
                    
                    <textarea id="userInput" class="flex-1 bg-transparent border-none focus:ring-0 text-on-surface font-body-md text-sm resize-none py-3 px-0 placeholder-outline/50 max-h-32 min-h-[44px]" placeholder="Hỏi Trợ lý AI về học liệu môn học..." rows="1" autocomplete="off" required></textarea>
                    
                    <button type="submit" class="p-3 text-tertiary hover:text-tertiary-fixed-dim transition-colors flex items-center justify-center" id="sendBtn">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">send</span>
                    </button>
                </div>
            </form>
            <div class="text-center mt-2 select-none">
                <span class="font-label-md text-[10px] text-outline">AI có thể đưa ra câu trả lời không chính xác. Hãy kiểm tra các nguồn thông tin.</span>
            </div>
        </div>
    </section>
    
</div>

<!-- Citation Details Popover (NotebookLM Style) -->
<div id="citationPopover" class="absolute hidden z-50 max-w-sm bg-surface-container-highest border border-outline-variant/60 rounded-xl shadow-lg p-4 transition-opacity duration-150 select-none">
    <div class="flex items-center gap-2 mb-2 pb-1.5 border-b border-outline-variant/30">
        <span class="w-5 h-5 flex items-center justify-center text-[10px] font-bold rounded-full bg-primary text-on-primary flex-shrink-0" id="popoverIndex">1</span>
        <span class="text-xs font-semibold text-on-surface truncate flex-1" id="popoverFileName">Tài liệu</span>
        <span class="text-[10px] text-outline font-medium" id="popoverPageNumber">Trang 1</span>
    </div>
    <div class="text-xs text-on-surface-variant leading-relaxed italic line-clamp-6 max-h-48 overflow-y-auto" id="popoverContent">
        Nội dung...
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        const chatForm = document.getElementById('chatForm');
        const userInput = document.getElementById('userInput');
        const chatMessages = document.getElementById('chatMessages');
        const sendBtn = document.getElementById('sendBtn');
        const modelSelector = document.getElementById('modelSelector');
        const subjectId = '@Model.Id';

        // Citation Popover Logic
        const popover = document.getElementById('citationPopover');
        let activePopoverTimer = null;

        if (popover) {
            popover.addEventListener('mouseenter', () => {
                clearTimeout(activePopoverTimer);
            });
            popover.addEventListener('mouseleave', hidePopover);
        }

        function showPopover(element, index, sources) {
            clearTimeout(activePopoverTimer);
            if (!popover) return;
            
            const source = sources.find(s => s.index === index);
            if (!source) return;

            document.getElementById('popoverIndex').textContent = source.index;
            document.getElementById('popoverFileName').textContent = source.fileName;
            document.getElementById('popoverPageNumber').textContent = source.pageNumber ? `Trang ${source.pageNumber}` : 'Tài liệu';
            document.getElementById('popoverContent').textContent = source.content;

            popover.classList.remove('hidden');

            const rect = element.getBoundingClientRect();
            const popoverRect = popover.getBoundingClientRect();
            
            // Position above
            let top = rect.top + window.scrollY - popoverRect.height - 10;
            if (top < window.scrollY + 10) {
                top = rect.bottom + window.scrollY + 10;
            }
            
            // Horizontally centered
            let left = rect.left + window.scrollX + (rect.width / 2) - (popoverRect.width / 2);
            if (left < 10) left = 10;
            if (left + popoverRect.width > window.innerWidth - 10) {
                left = window.innerWidth - popoverRect.width - 10;
            }

            popover.style.top = `${top}px`;
            popover.style.left = `${left}px`;
        }

        function hidePopover() {
            activePopoverTimer = setTimeout(() => {
                if (popover) {
                    popover.classList.add('hidden');
                }
            }, 200);
        }

        // Auto resize textarea
        userInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

        // Submit form on Enter key (without Shift)
        userInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                chatForm.dispatchEvent(new Event('submit'));
            }
        });

        function setQuery(text) {
            userInput.value = text;
            userInput.focus();
            // Trigger height update
            userInput.style.height = 'auto';
            userInput.style.height = (userInput.scrollHeight) + 'px';
        }

        // --- Document selection helpers ---
        function getSelectedDocIds() {
            return Array.from(document.querySelectorAll('.doc-checkbox:checked'))
                        .map(cb => cb.value);
        }

        function onDocCheckboxChange() {
            const selected = getSelectedDocIds();
            const total = document.querySelectorAll('.doc-checkbox').length;
            const toggleBtn = document.getElementById('toggleSelectAll');

            if (toggleBtn) {
                toggleBtn.textContent = selected.length === total ? 'Bỏ chọn tất cả' : 'Chọn tất cả';
            }
        }

        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('.doc-checkbox');
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !allChecked);
            onDocCheckboxChange();
        }

        // Init badge state
        onDocCheckboxChange();

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const query = userInput.value.trim();
            if (!query) return;

            // Clear input and disable
            userInput.value = '';
            userInput.disabled = true;
            sendBtn.disabled = true;
            userInput.style.height = 'auto'; // Reset height

            // Append User message
            appendMessage(query, 'user');
            scrollToBottom();

            // Append AI typing indicator
            const typingIndicatorId = appendTypingIndicator();
            scrollToBottom();

            try {
                // Get verification token
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // Get selected model
                const selectedModel = modelSelector ? modelSelector.value : 'gemini-2.5-flash';

                // Get selected document IDs (empty = use all docs)
                const selectedDocIds = getSelectedDocIds().join(',');

                // Send AJAX POST
                const response = await fetch('/Subject/SendMessage', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `subjectId=${encodeURIComponent(subjectId)}&message=${encodeURIComponent(query)}&model=${encodeURIComponent(selectedModel)}&documentIds=${encodeURIComponent(selectedDocIds)}`
                });

                const data = await response.json();
                removeTypingIndicator(typingIndicatorId);

                if (data.success) {
                    appendMessage(data.reply, 'ai', data.sources);
                } else {
                    appendMessage(`Lỗi hệ thống: ${data.message}`, 'ai');
                }
            } catch (err) {
                removeTypingIndicator(typingIndicatorId);
                appendMessage(`Lỗi đường truyền: Không thể kết nối tới Trợ lý AI. ${err.message}`, 'ai');
            } finally {
                userInput.disabled = false;
                sendBtn.disabled = false;
                userInput.focus();
                scrollToBottom();
            }
        });

        function appendMessage(text, sender, sources = []) {
            const messageWrapper = document.createElement('div');
            messageWrapper.classList.add('flex', 'flex-col', sender === 'user' ? 'items-end' : 'items-start', 'w-full', 'gap-1');

            if (sender === 'ai') {
                let html = marked.parse(text);
                
                // Replace inline citations [X] with pretty badges
                html = html.replace(/\[(\d+)\]/g, (match, number) => {
                    const idx = parseInt(number);
                    const sourceExists = sources && sources.some(s => s.index === idx);
                    if (sourceExists) {
                        return `<button type="button" class="citation-badge inline-flex items-center justify-center w-5 h-5 ml-1 mr-0.5 text-[9px] font-bold rounded-full bg-primary/15 text-primary hover:bg-primary/25 border border-primary/20 cursor-pointer select-none transition-all focus:outline-none align-middle" style="margin-top: -3px;" data-index="${idx}">${idx}</button>`;
                    }
                    return match;
                });

                // Construct sources card container
                let sourcesHtml = '';
                if (sources && sources.length > 0) {
                    sourcesHtml = `
                        <div class="mt-3 pt-3 border-t border-outline-variant/30 text-xs w-full select-none">
                            <div class="flex items-center gap-1.5 text-on-surface-variant font-bold mb-2">
                                <span class="material-symbols-outlined text-[16px] text-primary">menu_book</span>
                                Nguồn tài liệu tham khảo
                            </div>
                            <div class="flex flex-wrap gap-2">
                    `;
                    sources.forEach(source => {
                        sourcesHtml += `
                            <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-xl bg-surface-container-low hover:bg-surface-container border border-outline-variant/30 hover:border-outline-variant/60 transition-all cursor-pointer citation-source-card max-w-[200px]" data-index="${source.index}">
                                <span class="w-4.5 h-4.5 flex items-center justify-center text-[9px] font-bold rounded-full bg-primary text-on-primary flex-shrink-0">${source.index}</span>
                                <div class="min-w-0 flex-1">
                                    <div class="text-[10px] font-semibold text-on-surface truncate" title="${source.fileName}">${source.fileName}</div>
                                    ${source.pageNumber ? `<div class="text-[8px] text-outline font-medium">Trang ${source.pageNumber}</div>` : `<div class="text-[8px] text-outline font-medium">Tài liệu</div>`}
                                </div>
                            </div>
                        `;
                    });
                    sourcesHtml += `
                            </div>
                        </div>
                    `;
                }

                messageWrapper.innerHTML = `
                    <div class="flex items-center gap-2 px-1 select-none">
                        <span class="material-symbols-outlined text-tertiary text-[16px] filled">smart_toy</span>
                        <span class="font-label-md text-label-md text-on-surface-variant text-[10px]">Trợ lý Học tập AI</span>
                    </div>
                    <div class="bg-surface text-on-surface font-body-md text-sm px-4 py-3 rounded-2xl rounded-tl-sm w-full border border-outline-variant shadow-sm leading-relaxed markdown-body">
                        <div class="prose max-w-none text-sm leading-relaxed">${html}</div>
                        ${sourcesHtml}
                    </div>
                `;
            } else {
                messageWrapper.innerHTML = `
                    <div class="bg-surface-container-highest border border-outline-variant text-on-surface font-body-md text-sm px-4 py-2.5 rounded-2xl rounded-tr-sm max-w-[75%] leading-relaxed shadow-sm">
                        ${escapeHtml(text)}
                    </div>
                `;
            }

            chatMessages.appendChild(messageWrapper);

            // Attach listeners to new elements
            if (sender === 'ai' && sources && sources.length > 0) {
                const badges = messageWrapper.querySelectorAll('.citation-badge');
                badges.forEach(badge => {
                    const idx = parseInt(badge.getAttribute('data-index'));
                    badge.addEventListener('mouseenter', () => showPopover(badge, idx, sources));
                    badge.addEventListener('mouseleave', hidePopover);
                });

                const cards = messageWrapper.querySelectorAll('.citation-source-card');
                cards.forEach(card => {
                    const idx = parseInt(card.getAttribute('data-index'));
                    card.addEventListener('mouseenter', () => showPopover(card, idx, sources));
                    card.addEventListener('mouseleave', hidePopover);
                });
            }
        }

        function escapeHtml(string) {
            return String(string).replace(/[&<>"']/g, function (s) {
                return {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                }[s];
            });
        }

        function appendTypingIndicator() {
            const id = 'typing-' + Date.now();
            const messageWrapper = document.createElement('div');
            messageWrapper.id = id;
            messageWrapper.classList.add('flex', 'flex-col', 'items-start', 'w-full', 'gap-1');
            
            messageWrapper.innerHTML = `
                <div class="flex items-center gap-2 px-1 select-none">
                    <span class="material-symbols-outlined text-tertiary text-[16px] filled">smart_toy</span>
                </div>
                <div class="bg-surface text-on-surface font-body-md text-sm px-4 py-3 rounded-2xl rounded-tl-sm border border-outline-variant flex gap-1 items-center h-10 w-16 shadow-sm select-none">
                    <div class="w-1.5 h-1.5 bg-tertiary rounded-full animate-bounce" style="animation-delay: 0ms"></div>
                    <div class="w-1.5 h-1.5 bg-tertiary rounded-full animate-bounce" style="animation-delay: 150ms"></div>
                    <div class="w-1.5 h-1.5 bg-tertiary rounded-full animate-bounce" style="animation-delay: 300ms"></div>
                </div>
            `;

            chatMessages.appendChild(messageWrapper);
            return id;
        }

        function removeTypingIndicator(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        function scrollToBottom() {
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
    </script>
}
