@{
    ViewData["Title"] = "Create Subject";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Subjects</a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 16px;">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-3" style="color: #1a1f36;">Create Subject</h2>
            <p class="text-muted mb-4">Register a new course subject and assign a lecturer to manage it.</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label for="subjectCode" class="form-label fw-semibold">Subject Code</label>
                    <input type="text" name="subjectCode" id="subjectCode" class="form-control" placeholder="e.g., PRN222" required />
                    <small class="text-muted">Must be unique (e.g. INT101, PRN211)</small>
                </div>

                <div class="mb-3">
                    <label for="name" class="form-label fw-semibold">Subject Name</label>
                    <input type="text" name="name" id="name" class="form-control" placeholder="e.g., Web Application Development" required />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label fw-semibold">Description</label>
                    <textarea name="description" id="description" rows="3" class="form-control" placeholder="Brief details about the subject..."></textarea>
                </div>

                <div class="mb-4">
                    <label for="lecturerId" class="form-label fw-semibold">Assign Lecturer</label>
                    <select name="lecturerId" id="lecturerId" class="form-select" asp-items="ViewBag.Lecturers">
                        <option value="">-- Choose Lecturer (Optional) --</option>
                    </select>
                    <small class="text-muted">Only one Lecturer can be assigned per subject.</small>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2.5 fw-semibold" style="border-radius: 10px; background-color: #4f46e5; border-color: #4f46e5;">
                    Create Subject
                </button>
            </form>
        </div>
    </div>
</div>
