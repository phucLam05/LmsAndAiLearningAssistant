@model Core.Entities.Document
@{
    ViewData["Title"] = "Chi tiết học liệu AI";
}

<div class="max-w-5xl mx-auto space-y-6 select-none animate-fade-in">
    <!-- Breadcrumb / Actions Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <a class="inline-flex items-center gap-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high px-4 py-2 rounded-lg transition-colors text-xs font-semibold border border-outline-variant/30" asp-action="Portal" asp-route-selectedSubjectId="@Model.SubjectId">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span> Không gian làm việc
            </a>
            <h1 class="font-headline-lg text-headline-lg font-bold text-on-surface mt-3 tracking-tight truncate max-w-xl" title="@Model.FileName">@Model.FileName</h1>
            <p class="text-xs text-on-surface-variant mt-1">Kiểm tra các phân đoạn văn bản và trọng số vector được khởi tạo để phục vụ tìm kiếm ngữ nghĩa RAG.</p>
        </div>
        <a class="inline-flex items-center gap-2 bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed px-4 py-2.5 rounded-xl font-label-md text-xs font-bold transition-all shadow-md select-none self-start sm:self-center" asp-action="ViewOriginal" asp-route-id="@Model.Id" target="_blank">
            <span class="material-symbols-outlined text-[16px]">download</span> Xem tập tin gốc
        </a>
    </div>

    <!-- Metadata Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Info Details Panel -->
        <div class="md:col-span-2 bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm space-y-4">
            <h3 class="font-label-md text-label-md text-on-surface font-bold uppercase tracking-wider text-[11px] border-b border-outline-variant/20 pb-2">Thông tin học liệu</h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <span class="text-[10px] text-outline uppercase font-semibold block">Tên tập tin</span>
                    <span class="text-xs text-on-surface font-bold break-all">@Model.FileName</span>
                </div>
                <div>
                    <span class="text-[10px] text-outline uppercase font-semibold block">Định dạng</span>
                    @{
                        var ext = System.IO.Path.GetExtension(Model.FileName)?.TrimStart('.') ?? "N/A";
                    }
                    <span class="inline-block bg-surface-container-highest border border-outline-variant text-[10px] font-mono text-outline font-bold px-2 py-0.5 rounded uppercase mt-0.5">
                        @ext
                    </span>
                </div>
                <div>
                    <span class="text-[10px] text-outline uppercase font-semibold block">Trạng thái xử lý</span>
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold bg-tertiary-container/20 border-tertiary/20 text-tertiary mt-0.5">
                        <span class="material-symbols-outlined text-[12px] filled">check_circle</span>
                        @Model.Status
                    </span>
                </div>
                <div>
                    <span class="text-[10px] text-outline uppercase font-semibold block">Ngày tải lên</span>
                    <span class="text-xs text-on-surface font-bold">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                </div>
            </div>
        </div>

        <!-- RAG Vector Stats Panel -->
        <div class="md:col-span-1 bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm space-y-4">
            <h3 class="font-label-md text-label-md text-on-surface font-bold uppercase tracking-wider text-[11px] border-b border-outline-variant/20 pb-2">Thống kê vector RAG</h3>
            
            <div class="grid grid-cols-2 gap-3">
                <div class="p-3 bg-surface-container-lowest border border-outline-variant/40 rounded-xl text-center">
                    <div class="text-lg font-bold text-primary">@Model.Chunks.Count</div>
                    <div class="text-[9px] text-outline uppercase font-bold mt-0.5">Phân đoạn (Chunks)</div>
                </div>
                <div class="p-3 bg-surface-container-lowest border border-outline-variant/40 rounded-xl text-center">
                    <div class="text-lg font-bold text-primary">1536</div>
                    <div class="text-[9px] text-outline uppercase font-bold mt-0.5">Số chiều vector</div>
                </div>
            </div>
            
            <div class="pt-1.5">
                <span class="text-[10px] text-outline uppercase font-semibold block">Mô hình trích xuất (Embedding)</span>
                <span class="text-xs text-on-surface font-bold">pgvector (text-embedding-3-small)</span>
            </div>
        </div>
    </div>

    <!-- Chunks List Section -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm space-y-5">
        <h3 class="font-headline-sm text-sm font-bold text-on-surface flex items-center gap-2 border-b border-outline-variant/20 pb-3">
            <span class="material-symbols-outlined text-primary text-[20px]">join_inner</span>
            Danh sách phân đoạn văn bản học liệu (AI Generated Chunks)
        </h3>

        @if (!Model.Chunks.Any())
        {
            <div class="text-center py-12 text-outline">
                <span class="material-symbols-outlined text-[36px] text-outline/60 mb-2">view_headline</span>
                <p class="text-xs">Tài liệu này chưa có phân đoạn văn bản nào được khởi tạo.</p>
            </div>
        }
        else
        {
            <div class="space-y-5">
                @foreach (var chunk in Model.Chunks.OrderBy(c => c.ChunkIndex))
                {
                    <div class="bg-surface-container-lowest border border-outline-variant/40 rounded-2xl p-5 space-y-4 hover:border-outline-variant transition-all">
                        <div class="flex justify-between items-center pb-2.5 border-b border-outline-variant/20">
                            <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-full text-[10px] font-bold">
                                Phân đoạn #@(chunk.ChunkIndex + 1)
                            </span>
                        </div>
                        
                        <!-- Chunk Content -->
                        <div class="space-y-1.5">
                            <span class="text-[10px] text-outline font-bold uppercase tracking-wider flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">format_quote</span>
                                Nội dung văn bản trích xuất
                            </span>
                            <p class="text-xs text-on-surface-variant leading-relaxed p-4 bg-surface-container-low/50 border-l-4 border-primary rounded-r-xl whitespace-pre-wrap">@chunk.Content</p>
                        </div>

                        <!-- Embedding Vector Preview -->
                        <div class="space-y-1.5">
                            <span class="text-[10px] text-outline font-bold uppercase tracking-wider flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">query_stats</span>
                                Trọng số nhúng vector (Preview 15 chiều đầu tiên)
                            </span>
                            <div class="p-3 font-mono text-[10px] text-on-surface-variant bg-surface-container-low rounded-xl border border-outline-variant/30 break-all select-all leading-normal tracking-wide">
                                @if (chunk.Embedding != null)
                                {
                                    var vals = chunk.Embedding.ToArray();
                                    var preview = string.Join(", ", vals.Take(15).Select(v => v.ToString("F6"))) + "...";
                                    <span>[ @preview ]</span>
                                }
                                else
                                {
                                    <span>[ 0.000000, 0.000000, 0.000000, ... ]</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

