@model Core.Entities.Document
@{
    ViewData["Title"] = "Document Embed Details";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a class="btn btn-sm btn-outline-secondary mb-2" asp-action="Portal" asp-route-selectedSubjectId="@Model.SubjectId">
                    <i class="bi bi-arrow-left"></i> Back to Workspace
                </a>
                <h1 class="document-title mb-0">@Model.FileName</h1>
                <p class="text-muted small mb-0">Inspect embedded text chunks and vector weights generated for semantic search.</p>
            </div>
            <a class="btn btn-primary" asp-action="ViewOriginal" asp-route-id="@Model.Id" target="_blank">
                <i class="bi bi-file-earmark-arrow-down"></i> View Original File
            </a>
        </div>

        <div class="admin-shell mb-4">
            <!-- Left panel: Metadata Info Card -->
            <div class="app-card p-4">
                <h4 class="fw-bold mb-3 text-dark">Document Information</h4>
                
                <div class="d-flex flex-column gap-3">
                    <div>
                        <span class="text-muted small d-block">File Name</span>
                        <strong class="text-dark">@Model.FileName</strong>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Extension</span>
                            @{
                                var ext = System.IO.Path.GetExtension(Model.FileName)?.TrimStart('.') ?? "N/A";
                            }
                            <span class="badge bg-secondary font-monospace text-uppercase">@ext</span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Processing Status</span>
                            <span class="badge bg-success">@Model.Status</span>
                        </div>
                        <div class="col-sm-6">
                            <span class="text-muted small d-block">Uploaded At</span>
                            <strong class="text-dark">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right panel: Quick Stats -->
            <div class="app-card p-4 align-self-start">
                <h4 class="fw-bold mb-3 text-dark">RAG Vector Statistics</h4>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 bg-light border rounded text-center">
                            <div class="fs-3 fw-bold text-primary">@Model.Chunks.Count</div>
                            <div class="text-muted small">Total Chunks</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light border rounded text-center">
                            <div class="fs-3 fw-bold text-primary">3072</div>
                            <div class="text-muted small">Vector Dim</div>
                        </div>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="text-muted small d-block">Embedding Model</span>
                    <strong class="text-dark">pgvector (text-embedding-3-small / custom)</strong>
                </div>
            </div>
        </div>

        <!-- Chunks list -->
        <div class="app-card p-4">
            <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-bezier2 text-primary me-1"></i>Generated Embed Chunks</h4>

            @if (!Model.Chunks.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-journal-text fs-1 d-block mb-2 text-secondary"></i>
                    No chunks generated yet. Run background pipeline to index this file.
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-4">
                    @foreach (var chunk in Model.Chunks.OrderBy(c => c.ChunkIndex))
                    {
                        <div class="border rounded-3 p-4 bg-white shadow-xs">
                            <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
                                <span class="badge bg-primary rounded-pill small">Chunk #@(chunk.ChunkIndex + 1)</span>
                            </div>
                            
                            <!-- Chunk Content -->
                            <div class="mb-3">
                                <span class="text-muted small d-block mb-1.5 fw-bold"><i class="bi bi-quote"></i> Extracted Segment</span>
                                <p class="text-dark mb-0 p-3 bg-light border rounded" style="font-size:0.92rem; line-height:1.6; border-left: 4px solid var(--bs-primary) !important;">
                                    @chunk.Content
                                </p>
                            </div>

                            <!-- Embedding Vector Preview -->
                            <div>
                                <span class="text-muted small d-block mb-1 fw-bold"><i class="bi bi-graph-up me-1"></i> Embedding Weights (First 15 dimensions)</span>
                                <div class="p-2.5 font-monospace text-muted small bg-dark text-light border rounded" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                                    @if (chunk.Embedding != null)
                                    {
                                        var vals = chunk.Embedding.ToArray();
                                        var preview = string.Join(", ", vals.Take(15).Select(v => v.ToString("F6"))) + "...";
                                        <span>[ @preview ]</span>
                                    }
                                    else
                                    {
                                        <span>[ 0.000000, 0.000000, 0.000000, ... ]</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
