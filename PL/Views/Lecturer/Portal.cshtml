@model List<PL.Controllers.LecturerController.MockLecturerDoc>
@{
    ViewData["Title"] = "Không gian Giảng viên";
    var subjects = ViewBag.Subjects as List<PL.Controllers.LecturerController.MockSubject> ?? new();
    var selectedSubjectId = ViewBag.SelectedSubjectId as string;
    var selectedSubject = ViewBag.SelectedSubject as PL.Controllers.LecturerController.MockSubject;
}

<!-- Page Header -->
<div class="mb-6 select-none animate-fade-in">
    <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-xs font-mono font-bold tracking-tight">
        Lecturer Workspace
    </span>
    <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface mt-2 tracking-tight">Không gian Giảng viên</h1>
    <p class="font-body-md text-xs text-on-surface-variant mt-1">Quản lý tài liệu học tập, giáo trình môn học và cấu hình cơ sở tri thức AI.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6 select-none animate-fade-in">
    <!-- Left Sidebar: Subjects list -->
    <aside class="lg:col-span-1 bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 flex flex-col space-y-4 shadow-sm self-start">
        <div>
            <h3 class="font-label-md text-label-md text-on-surface font-bold uppercase tracking-wider text-[11px] mb-2">Môn học được phân công</h3>
            <p class="text-xs text-on-surface-variant mb-4 leading-relaxed">Chọn một môn học để xem tài nguyên và cập nhật tài liệu.</p>
            
            <div class="flex flex-col gap-1.5">
                @foreach (var subject in subjects)
                {
                    <a asp-action="Portal" asp-route-selectedSubjectId="@subject.Id" 
                       class="flex items-center justify-between px-3 py-2.5 rounded-xl text-xs transition-all border group @(subject.Id == selectedSubjectId ? "bg-secondary-container border-primary/20 text-on-secondary-container font-bold" : "border-transparent text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface")">
                        <div class="flex items-center gap-2 min-w-0">
                            <span class="material-symbols-outlined text-[16px] @(subject.Id == selectedSubjectId ? "text-primary filled" : "text-outline group-hover:text-on-surface")">folder</span>
                            <span class="truncate pr-1" title="@subject.Name">@subject.Code - @subject.Name</span>
                        </div>
                        <span class="px-2 py-0.5 rounded-md text-[10px] font-bold @(subject.Id == selectedSubjectId ? "bg-primary-container text-on-primary-container" : "bg-surface-container-highest border border-outline-variant/40 text-outline")">
                            @subject.DocumentCount
                        </span>
                    </a>
                }
            </div>
        </div>

        <div class="border-t border-outline-variant/30 pt-4 mt-auto">
            <h4 class="font-label-md text-label-md text-on-surface-variant font-bold uppercase tracking-wider text-[10px] mb-1.5">Kiểm định nội dung</h4>
            <p class="text-[11px] text-outline leading-relaxed">
                Tất cả tài liệu được tải lên sẽ tự động chạy qua mô hình AI để chia nhỏ (Chunking) và tạo vector nhúng (Embeddings). Giảng viên cần kiểm tra độ chính xác sau khi hệ thống xử lý xong.
            </p>
        </div>
    </aside>

    <!-- Center/Right Panel: Subject Workspace & File Upload -->
    <section class="lg:col-span-3 space-y-6">
        @if (selectedSubject != null)
        {
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4 select-none">
                    <div class="flex items-center gap-2.5 min-w-0">
                        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-xs font-mono font-bold tracking-tight">
                            @selectedSubject.Code
                        </span>
                        <h3 class="font-headline-sm text-headline-sm font-bold text-on-surface truncate">@selectedSubject.Name</h3>
                    </div>
                    <a asp-controller="Subject" asp-action="Chat" asp-route-subjectId="@selectedSubject.Id" class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed rounded-xl text-xs font-bold transition-all shadow-sm shrink-0">
                        <span class="material-symbols-outlined text-[16px] filled">smart_toy</span>
                        Hỏi Trợ lý AI
                    </a>
                </div>
                <p class="text-xs text-on-surface-variant leading-relaxed mb-6">Tải lên bài giảng, slide thuyết trình hoặc tài liệu tham khảo để làm phong phú thêm cơ sở dữ liệu tri thức của Trợ lý AI.</p>

                <!-- Drag & Drop Upload Zone -->
                <div class="space-y-3">
                    <h4 class="font-label-md text-label-md text-on-surface-variant font-bold uppercase tracking-wider text-[11px]">Tải lên tài liệu học liệu</h4>
                    <div class="bg-surface-container-lowest border-2 border-dashed border-outline-variant/50 hover:border-primary hover:bg-surface-container-low rounded-2xl p-8 flex flex-col items-center justify-center text-center cursor-pointer transition-all duration-200 group" id="docDropzone">
                        <span class="material-symbols-outlined text-[42px] text-outline group-hover:text-primary transition-colors mb-3">cloud_upload</span>
                        <h5 class="font-body-lg text-xs font-bold text-on-surface mb-1">Kéo thả tài liệu vào đây, hoặc click để duyệt tập tin</h5>
                        <p class="text-[10px] text-outline">Hỗ trợ PDF, DOCX, PPTX, XLSX, TXT - Dung lượng tối đa 50MB</p>
                        <input type="file" id="docFileInput" accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt" class="hidden" />
                    </div>

                    <!-- Live Upload Progress -->
                    <div id="uploadProgressCard" class="bg-surface-container-high border border-outline-variant/40 rounded-2xl p-4 shadow-sm" style="display:none;">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-[28px] text-primary" id="uploadFileIcon">description</span>
                                <div>
                                    <strong id="uploadFileName" class="text-xs text-on-surface block truncate max-w-[240px]">lecture_file.pdf</strong>
                                    <span id="uploadFileSize" class="text-[10px] text-outline mt-0.5 block">4.2 MB</span>
                                </div>
                            </div>
                            <span class="text-xs font-mono font-bold text-primary" id="uploadPercent">0%</span>
                        </div>
                        <div class="w-full h-1.5 bg-surface-container-lowest rounded-full overflow-hidden mb-2">
                            <div class="h-full bg-primary transition-all duration-200" id="uploadProgressBar" style="width: 0%"></div>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-[10px] text-on-surface-variant" id="uploadStatusText">Đang chuẩn bị tải tài liệu lên Supabase...</span>
                            <span class="w-2 h-2 rounded-full bg-primary animate-ping" id="uploadPulse" style="display:none;"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Processing Tracker Table -->
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="font-headline-sm text-sm font-bold text-on-surface">Danh sách tài liệu môn học</h3>
                    <span id="docCountBadge" class="text-[11px] text-outline font-semibold">Tổng số: @Model.Count tài liệu</span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-xs" id="trackerTable">
                        <thead>
                            <tr class="border-b border-outline-variant/30 text-outline uppercase text-[10px] tracking-wider">
                                <th class="pb-3 font-bold">Tên học liệu</th>
                                <th class="pb-3 font-bold">Dung lượng</th>
                                <th class="pb-3 font-bold">Người đăng</th>
                                <th class="pb-3 font-bold">Trạng thái xử lý</th>
                                <th class="pb-3 font-bold">Ngày tải lên</th>
                                <th class="pb-3 font-bold text-right">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="trackerTableBody" class="divide-y divide-outline-variant/10">
                            @if (!Model.Any())
                            {
                                <tr id="emptyTrackerRow">
                                    <td colspan="6" class="text-center py-12 text-outline">
                                        <span class="material-symbols-outlined text-[36px] text-outline/60 mb-2">folder_open</span>
                                        <p class="text-xs">Môn học này chưa được tải tài liệu giảng dạy nào.</p>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var doc in Model)
                                {
                                    var fileExtension = doc.FileName.Split('.').Last().ToLower();
                                    var iconName = fileExtension switch
                                    {
                                        "pdf" => "picture_as_pdf",
                                        "docx" or "doc" => "description",
                                        "pptx" or "ppt" => "slideshow",
                                        "xlsx" or "xls" => "table_chart",
                                        _ => "text_snippet"
                                    };
                                    var iconColor = fileExtension switch
                                    {
                                        "pdf" => "text-red-400",
                                        "docx" or "doc" => "text-blue-400",
                                        "pptx" or "ppt" => "text-amber-400",
                                        "xlsx" or "xls" => "text-emerald-400",
                                        _ => "text-on-surface-variant"
                                    };

                                    var statusClass = doc.Status switch
                                    {
                                        "Pending" => "bg-surface-container-highest border-outline-variant/40 text-outline",
                                        "Processing" => "bg-primary/10 border-primary/20 text-primary",
                                        "Failed" => "bg-error-container/20 border-error/20 text-error",
                                        _ => "bg-tertiary-container/20 border-tertiary/20 text-tertiary"
                                    };

                                    <tr data-doc-id="@doc.Id" data-status="@doc.Status" class="hover:bg-surface-container/20 transition-all">
                                        <td class="py-3.5 pr-2">
                                            <div class="flex items-center gap-2.5 min-w-0">
                                                <span class="material-symbols-outlined @iconColor text-[20px] select-none">@iconName</span>
                                                <span class="font-bold text-on-surface truncate max-w-[200px]" title="@doc.FileName">@doc.FileName</span>
                                            </div>
                                        </td>
                                        <td class="py-3.5 text-on-surface-variant">@doc.FileSizeStr</td>
                                        <td class="py-3.5 text-on-surface-variant">@doc.StoredBy</td>
                                        <td class="py-3.5 status-cell">
                                            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold @statusClass select-none">
                                                @if (doc.Status == "Processing")
                                                {
                                                    <span class="w-3 h-3 border-2 border-t-transparent border-primary rounded-full animate-spin"></span>
                                                }
                                                else if (doc.Status == "Pending")
                                                {
                                                    <span class="material-symbols-outlined text-[12px]">schedule</span>
                                                }
                                                else if (doc.Status == "Success")
                                                {
                                                    <span class="material-symbols-outlined text-[12px] filled">check_circle</span>
                                                }
                                                else
                                                {
                                                    <span class="material-symbols-outlined text-[12px]">cancel</span>
                                                }
                                                @doc.Status
                                            </span>
                                        </td>
                                        <td class="py-3.5 text-on-surface-variant">@doc.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="py-3.5 text-right">
                                            <div class="flex justify-end gap-1.5 items-center">
                                                <!-- Tải xuống tệp gốc -->
                                                <a class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-on-surface-variant hover:text-on-surface transition-colors flex items-center justify-center" 
                                                   asp-controller="Document" asp-action="ViewOriginal" asp-route-id="@doc.Id" target="_blank" title="Tải xuống tệp gốc từ Supabase">
                                                    <span class="material-symbols-outlined text-[16px] block">download</span>
                                                </a>
                                                
                                                <!-- Xem chi tiết Chunks -->
                                                @if (doc.Status == "Success")
                                                {
                                                    <a class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-primary transition-colors flex items-center justify-center" 
                                                       asp-controller="Document" asp-action="Details" asp-route-id="@doc.Id" title="Xem danh sách chunks & vector embeddings">
                                                        <span class="material-symbols-outlined text-[16px] block">table_chart</span>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="p-1.5 bg-surface border border-outline-variant/30 text-outline/40 rounded-xl cursor-not-allowed select-none flex items-center justify-center" 
                                                            disabled title="Xem chunks sau khi AI trích xuất hoàn tất">
                                                        <span class="material-symbols-outlined text-[16px] block">table_chart</span>
                                                    </button>
                                                }

                                                <!-- Thử lại AI Indexing nếu bị lỗi -->
                                                @if (doc.Status == "Failed")
                                                {
                                                    <form asp-controller="Document" asp-action="RetryProcessing" method="post" class="inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@doc.Id" />
                                                        <input type="hidden" name="subjectId" value="@selectedSubjectId" />
                                                        <input type="hidden" name="redirectUrl" value="/Lecturer/Portal?selectedSubjectId=@selectedSubjectId" />
                                                        <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-primary transition-colors flex items-center justify-center cursor-pointer border-0" title="Thử lại AI indexing">
                                                            <span class="material-symbols-outlined text-[16px] block">refresh</span>
                                                        </button>
                                                    </form>
                                                }

                                                <!-- Xóa tài liệu -->
                                                <form asp-controller="Document" asp-action="Delete" method="post" class="inline" data-delete-confirm="Bạn có chắc chắn muốn xóa tài liệu này?">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="subjectId" value="@selectedSubjectId" />
                                                    <input type="hidden" name="redirectUrl" value="/Lecturer/Portal?selectedSubjectId=@selectedSubjectId" />
                                                    <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-error-container/20 rounded-xl text-error transition-colors flex items-center justify-center cursor-pointer border-0" title="Xóa tài liệu">
                                                        <span class="material-symbols-outlined text-[16px] block">delete</span>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center shadow-sm">
                <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline border border-outline-variant/50 mb-4">
                    <span class="material-symbols-outlined text-[36px] text-outline/65">chrome_reader_mode</span>
                </div>
                <h4 class="font-headline-sm text-headline-sm font-bold text-on-surface mb-2">Chưa chọn môn học</h4>
                <p class="text-xs text-on-surface-variant max-w-sm leading-relaxed">Hãy lựa chọn một môn học được phân công giảng dạy ở cột bên trái để tải lên tài liệu học liệu và quản lý RAG pipelines.</p>
            </div>
        }
    </section>
</div>

<!-- Delete Loading Overlay -->
<div id="deleteLoadingOverlay" class="fixed inset-0 z-[9999] bg-background/80 backdrop-blur-sm flex flex-col items-center justify-center hidden">
    <div class="bg-surface-container-high border border-outline-variant/40 rounded-2xl p-8 flex flex-col items-center gap-4 shadow-2xl">
        <div class="w-14 h-14 rounded-full border-4 border-outline-variant border-t-error animate-spin"></div>
        <div class="text-center">
            <p class="font-bold text-on-surface text-sm">Đang xóa tài liệu...</p>
            <p class="text-xs text-on-surface-variant mt-1">Vui lòng không đóng trang này.</p>
        </div>
    </div>
</div>

<!-- Anti-forgery Token form for JavaScript posts -->
<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        const subjectId = "@selectedSubjectId";
        const dropzone = document.getElementById('docDropzone');
        const fileInput = document.getElementById('docFileInput');

        const progressCard = document.getElementById('uploadProgressCard');
        const progressBar = document.querySelector('#uploadProgressCard .progress-bar') || document.getElementById('uploadProgressBar');
        const progressPercent = document.getElementById('uploadPercent');
        const progressFileName = document.getElementById('uploadFileName');
        const progressFileSize = document.getElementById('uploadFileSize');
        const progressStatusText = document.getElementById('uploadStatusText');
        const progressPulse = document.getElementById('uploadPulse');
        const uploadFileIcon = document.getElementById('uploadFileIcon');

        // Drag & Drop event bindings
        dropzone?.addEventListener('click', () => fileInput.click());
        dropzone?.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('bg-surface-container-low', 'border-primary');
        });
        dropzone?.addEventListener('dragleave', () => {
            dropzone.classList.remove('bg-surface-container-low', 'border-primary');
        });
        dropzone?.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('bg-surface-container-low', 'border-primary');
            const files = e.dataTransfer.files;
            if (files.length) {
                uploadLecturerFile(files[0]);
            }
        });

        fileInput?.addEventListener('change', (e) => {
            const files = e.target.files;
            if (files.length) {
                uploadLecturerFile(files[0]);
            }
        });

        function uploadLecturerFile(file) {
            if (file.size > 50 * 1024 * 1024) {
                showNotification(`Tệp "${file.name}" vượt quá hạn mức 50MB.`, "warning");
                return;
            }

            // Set file metadata in progress card
            progressFileName.textContent = file.name;
            progressFileSize.textContent = `${(file.size / 1024 / 1024).toFixed(2)} MB`;

            // Icon swap based on extension
            const ext = file.name.split('.').pop().toLowerCase();
            let iconName = 'description';
            let iconColor = 'text-on-surface-variant';

            if (ext === 'pdf') { iconName = 'picture_as_pdf'; iconColor = 'text-red-400'; }
            else if (ext === 'doc' || ext === 'docx') { iconName = 'description'; iconColor = 'text-blue-400'; }
            else if (ext === 'ppt' || ext === 'pptx') { iconName = 'slideshow'; iconColor = 'text-amber-400'; }
            else if (ext === 'xls' || ext === 'xlsx') { iconName = 'table_chart'; iconColor = 'text-emerald-400'; }

            uploadFileIcon.className = `material-symbols-outlined text-[28px] ${iconColor}`;
            uploadFileIcon.textContent = iconName;

            // Reset Progress state
            progressBar.style.width = '0%';
            progressPercent.textContent = '0%';
            progressStatusText.textContent = 'Đang chuẩn bị tải tài liệu lên Supabase...';
            progressStatusText.className = "text-[10px] text-on-surface-variant";
            if (progressPulse) progressPulse.style.display = 'none';
            progressCard.style.display = 'block';

            const formData = new FormData();
            formData.append('file', file);
            formData.append('subjectId', subjectId);

            const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/Lecturer/UploadLecturerFile', true);
            xhr.setRequestHeader('RequestVerificationToken', token);

            xhr.upload.onprogress = function(e) {
                if (e.lengthComputable) {
                    const percentComplete = Math.round((e.loaded / e.total) * 100);
                    progressBar.style.width = `${percentComplete}%`;
                    progressPercent.textContent = `${percentComplete}%`;
                    if (percentComplete === 100) {
                        progressStatusText.textContent = 'Đang xử lý...';
                    }
                }
            };

            xhr.onload = function() {
                try {
                    if (xhr.status === 200) {
                        const data = JSON.parse(xhr.responseText);
                        if (data.success) {
                            progressCard.style.display = 'none';
                            addDocRowToTracker(data.document);
                            startStatusPolling(data.document.id);
                        } else {
                            showNotification("Lỗi tải lên: " + data.message, "error");
                            progressCard.style.display = 'none';
                        }
                    } else {
                        showNotification("Kết nối máy chủ thất bại, Status Code: " + xhr.status, "error");
                        progressCard.style.display = 'none';
                    }
                } catch (err) {
                    console.error("Error in onload file upload:", err);
                    showNotification("Lỗi xử lý kết quả", "error");
                    progressCard.style.display = 'none';
                }
            };

            xhr.onerror = function() {
                showNotification("Lỗi đường truyền mạng trong quá trình upload.", "error");
                progressCard.style.display = 'none';
            };

            xhr.send(formData);
        }

        function addDocRowToTracker(doc) {
            if (!doc) return;
            // Remove empty tracker row if exists
            document.getElementById('emptyTrackerRow')?.remove();

            const tbody = document.getElementById('trackerTableBody');
            if (!tbody) return;

            const tr = document.createElement('tr');
            tr.className = 'hover:bg-surface-container/20 transition-all';
            tr.setAttribute('data-doc-id', doc.id);
            tr.setAttribute('data-status', 'Pending');
            
            const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
            
            const fileName = doc.fileName || '';
            const ext = fileName.split('.').pop().toLowerCase();
            let iconName = 'description';
            let iconColor = 'text-on-surface-variant';
            
            if (ext === 'pdf') { iconName = 'picture_as_pdf'; iconColor = 'text-red-400'; }
            else if (ext === 'doc' || ext === 'docx') { iconName = 'description'; iconColor = 'text-blue-400'; }
            else if (ext === 'ppt' || ext === 'pptx') { iconName = 'slideshow'; iconColor = 'text-amber-400'; }
            else if (ext === 'xls' || ext === 'xlsx') { iconName = 'table_chart'; iconColor = 'text-emerald-400'; }

            // Parse creation date safely
            let dateStr = "";
            try {
                if (doc.createdAt) {
                    const dateObj = new Date(doc.createdAt);
                    if (!isNaN(dateObj.getTime())) {
                        const pad = (num) => String(num).padStart(2, '0');
                        dateStr = `${dateObj.getFullYear()}-${pad(dateObj.getMonth() + 1)}-${pad(dateObj.getDate())} ${pad(dateObj.getHours())}:${pad(dateObj.getMinutes())}`;
                    } else {
                        dateStr = doc.createdAt.replace('T', ' ').slice(0, 16);
                    }
                }
            } catch (e) {
                console.error("Error parsing date:", e);
                dateStr = (doc.createdAt || "").replace('T', ' ').slice(0, 16);
            }

            tr.innerHTML = `
                <td class="py-3.5 pr-2">
                    <div class="flex items-center gap-2.5 min-w-0">
                        <span class="material-symbols-outlined ${iconColor} text-[20px] select-none">${iconName}</span>
                        <span class="font-bold text-on-surface truncate max-w-[200px]" title="${doc.fileName}">${doc.fileName}</span>
                    </div>
                </td>
                <td class="py-3.5 text-on-surface-variant">${doc.fileSizeStr}</td>
                <td class="py-3.5 text-on-surface-variant">${doc.storedBy}</td>
                <td class="py-3.5 status-cell">
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold bg-surface-container-highest border-outline-variant/40 text-outline select-none">
                        <span class="material-symbols-outlined text-[12px]">schedule</span> Pending
                    </span>
                </td>
                <td class="py-3.5 text-on-surface-variant">${dateStr}</td>
                <td class="py-3.5 text-right">
                    <div class="flex justify-end gap-1.5 items-center">
                        <a class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-on-surface-variant hover:text-on-surface transition-colors flex items-center justify-center" href="/Document/ViewOriginal/${doc.id}" target="_blank" title="Tải xuống tệp gốc từ Supabase">
                            <span class="material-symbols-outlined text-[16px] block">download</span>
                        </a>
                        <button class="p-1.5 bg-surface border border-outline-variant/30 text-outline/40 rounded-xl cursor-not-allowed select-none flex items-center justify-center" disabled title="Xem chunks sau khi AI trích xuất hoàn tất" data-id="${doc.id}">
                            <span class="material-symbols-outlined text-[16px] block">table_chart</span>
                        </button>
                        <form action="/Document/Delete" method="post" class="inline" data-delete-confirm="Bạn có chắc chắn muốn xóa tài liệu này?">
                            <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                            <input type="hidden" name="id" value="${doc.id}" />
                            <input type="hidden" name="subjectId" value="${subjectId}" />
                            <input type="hidden" name="redirectUrl" value="/Lecturer/Portal?selectedSubjectId=${subjectId}" />
                            <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-error-container/20 rounded-xl text-error transition-colors flex items-center justify-center cursor-pointer border-0" title="Xóa tài liệu">
                                <span class="material-symbols-outlined text-[16px] block">delete</span>
                            </button>
                        </form>
                    </div>
                </td>
            `;

            tbody.insertBefore(tr, tbody.firstChild);

            // Update counter badge
            const badge = document.getElementById('docCountBadge');
            if (badge) {
                const cur = parseInt(badge.textContent.replace(/[^\d]/g, '')) || 0;
                badge.textContent = `Tổng số: ${cur + 1} tài liệu`;
            }
        }

        const activePolls = new Set();

        function startStatusPolling(docId) {
            if (activePolls.has(docId)) return;
            activePolls.add(docId);

            const pollInterval = setInterval(() => {
                fetch(`/Document/GetStatus/${docId}`)
                    .then(res => {
                        if (!res.ok) throw new Error("Document status error");
                        return res.json();
                    })
                    .then(data => {
                        const tr = document.querySelector(`tr[data-doc-id="${docId}"]`);
                        if (!tr) {
                            clearInterval(pollInterval);
                            activePolls.delete(docId);
                            return;
                        }

                        const currentStatus = tr.getAttribute('data-status');
                        if (currentStatus !== data.status) {
                            tr.setAttribute('data-status', data.status);
                            updateRowStatusUI(tr, docId, data.status);
                        }

                        if (data.status === "Success" || data.status === "Failed") {
                            clearInterval(pollInterval);
                            activePolls.delete(docId);
                        }
                    })
                    .catch(err => {
                        console.error("Error polling document status:", err);
                        clearInterval(pollInterval);
                        activePolls.delete(docId);
                    });
            }, 3000);
        }

        function updateRowStatusUI(tr, docId, status) {
            const statusCell = tr.querySelector('.status-cell');
            if (!statusCell) return;

            let statusClass = "bg-surface-container-highest border-outline-variant/40 text-outline";
            let iconHtml = '<span class="material-symbols-outlined text-[12px]">schedule</span>';

            if (status === "Processing") {
                statusClass = "bg-primary/10 border-primary/20 text-primary";
                iconHtml = '<span class="w-3 h-3 border-2 border-t-transparent border-primary rounded-full animate-spin"></span>';
            } else if (status === "Success") {
                statusClass = "bg-tertiary-container/20 border-tertiary/20 text-tertiary";
                iconHtml = '<span class="material-symbols-outlined text-[12px] filled">check_circle</span>';
            } else if (status === "Failed") {
                statusClass = "bg-error-container/20 border-error/20 text-error";
                iconHtml = '<span class="material-symbols-outlined text-[12px]">cancel</span>';
            }

            statusCell.innerHTML = `
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold ${statusClass} select-none">
                    ${iconHtml} ${status}
                </span>
            `;

            const actionsCell = tr.querySelector('td:last-child div');
            if (actionsCell) {
                let chunksButton = "";
                let retryButton = "";

                if (status === "Success") {
                    chunksButton = `
                        <a class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-primary transition-colors flex items-center justify-center" 
                           href="/Document/Details/${docId}" title="Xem danh sách chunks & vector embeddings">
                            <span class="material-symbols-outlined text-[16px] block">table_chart</span>
                        </a>
                    `;
                } else {
                    chunksButton = `
                        <button class="p-1.5 bg-surface border border-outline-variant/30 text-outline/40 rounded-xl cursor-not-allowed select-none flex items-center justify-center" 
                                disabled title="Xem chunks sau khi AI trích xuất hoàn tất">
                            <span class="material-symbols-outlined text-[16px] block">table_chart</span>
                        </button>
                    `;
                }

                if (status === "Failed") {
                    const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
                    retryButton = `
                        <form action="/Document/RetryProcessing" method="post" class="inline">
                            <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                            <input type="hidden" name="id" value="${docId}" />
                            <input type="hidden" name="subjectId" value="${subjectId}" />
                            <input type="hidden" name="redirectUrl" value="/Lecturer/Portal?selectedSubjectId=${subjectId}" />
                            <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-primary transition-colors flex items-center justify-center cursor-pointer border-0" title="Thử lại AI indexing">
                                <span class="material-symbols-outlined text-[16px] block">refresh</span>
                            </button>
                        </form>
                    `;
                }

                const downloadButton = `
                    <a class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded-xl text-on-surface-variant hover:text-on-surface transition-colors flex items-center justify-center" 
                       href="/Document/ViewOriginal/${docId}" target="_blank" title="Tải xuống tệp gốc từ Supabase">
                        <span class="material-symbols-outlined text-[16px] block">download</span>
                    </a>
                `;

                const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value || '';
                const deleteButton = `
                    <form action="/Document/Delete" method="post" class="inline" data-delete-confirm="Bạn có chắc chắn muốn xóa tài liệu này?">
                        <input type="hidden" name="__RequestVerificationToken" value="${token}" />
                        <input type="hidden" name="id" value="${docId}" />
                        <input type="hidden" name="subjectId" value="${subjectId}" />
                        <input type="hidden" name="redirectUrl" value="/Lecturer/Portal?selectedSubjectId=${subjectId}" />
                        <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-error-container/20 rounded-xl text-error transition-colors flex items-center justify-center cursor-pointer border-0" title="Xóa tài liệu">
                            <span class="material-symbols-outlined text-[16px] block">delete</span>
                        </button>
                    </form>
                `;

                actionsCell.innerHTML = downloadButton + chunksButton + retryButton + deleteButton;
            }
        }

        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll("tr[data-doc-id]").forEach(tr => {
                const status = tr.getAttribute("data-status");
                if (status === "Pending" || status === "Processing") {
                    startStatusPolling(tr.getAttribute("data-doc-id"));
                }
            });
        });

        // Intercept delete forms to show loading overlay
        document.addEventListener("DOMContentLoaded", () => {
            document.addEventListener("submit", (e) => {
                const form = e.target.closest("form[data-delete-confirm]");
                if (!form) return;
                e.preventDefault();
                const msg = form.getAttribute("data-delete-confirm") || "Bạn có chắc chắn muốn xóa tài liệu này?";
                showConfirmModal(msg, () => {
                    document.getElementById("deleteLoadingOverlay").classList.remove("hidden");
                    form.submit();
                });
            });
        });
    </script>
}

