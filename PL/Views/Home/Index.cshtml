@{
    ViewData["Title"] = "LMS AI Learning Assistant";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<section class="home-shell">
    <div class="home-hero">
        <div class="home-hero-copy">
            <div class="document-eyebrow">RAG learning workspace</div>
            <h1>LMS AI Learning Assistant</h1>
            <p>
                Upload course materials, prepare them for extraction and embeddings, then ask questions grounded in your own documents.
            </p>
            <div class="home-actions">
                @if (isAuthenticated)
                {
                    <a class="btn btn-primary" asp-controller="Document" asp-action="Upload">Upload source</a>
                    <a class="btn btn-outline-secondary" asp-controller="Document" asp-action="Index">Manage documents</a>
                }
                else
                {
                    <a class="btn btn-primary" asp-controller="Auth" asp-action="Login">Login to start</a>
                    <a class="btn btn-outline-secondary" asp-controller="Auth" asp-action="Register">Create account</a>
                }
            </div>
        </div>

        <div class="home-chat-preview" aria-label="Chat preview">
            <div class="chat-preview-header">
                <span class="chat-dot"></span>
                <strong>Document Q&amp;A</strong>
                <small>Preview</small>
            </div>
            <div class="chat-message chat-message-user">Summarize the uploaded lecture slides for exam review.</div>
            <div class="chat-message chat-message-ai">
                I can answer after your sources are uploaded, extracted, chunked, and indexed by the RAG pipeline.
            </div>
            <div class="chat-input-preview">
                <span>Ask anything from your learning sources...</span>
                <button type="button" disabled>Ask</button>
            </div>
        </div>
    </div>

    <div class="home-workspace-grid">
        <aside class="home-sources-card">
            <div class="source-panel-title">Sources</div>
            <div class="source-panel-subtitle">Start with PDF, DOCX, or PPTX files.</div>
            <a class="source-upload-tile" asp-controller="Document" asp-action="Upload">
                <span class="source-upload-icon" aria-hidden="true">+</span>
                <span>
                    <strong>Add source</strong>
                    <small>Private Supabase Storage</small>
                </span>
            </a>
            <div class="home-source-types">
                <span>PDF</span>
                <span>DOCX</span>
                <span>PPTX</span>
            </div>
        </aside>

        <section class="home-rag-card">
            <div class="document-eyebrow">Pipeline</div>
            <h2>Ready for the team workflow</h2>
            <div class="rag-steps">
                <div>
                    <strong>1. Upload</strong>
                    <span>Store files in Supabase and save metadata.</span>
                </div>
                <div>
                    <strong>2. Extract &amp; chunk</strong>
                    <span>Read text from documents and split into chunks.</span>
                </div>
                <div>
                    <strong>3. Embed</strong>
                    <span>Generate vectors for semantic search.</span>
                </div>
                <div>
                    <strong>4. Ask</strong>
                    <span>Answer questions with citations from sources.</span>
                </div>
            </div>
        </section>
    </div>
</section>
