@model Core.DTOs.Documents.DocumentDto
@using Core.DTOs.Documents
@using Core.Entities
@{
    ViewData["Title"] = "Chi tiết Tài liệu";
    var chunks = ViewBag.Chunks as IReadOnlyList<DocumentChunkDto> ?? new List<DocumentChunkDto>();
    var totalTokens = chunks.Sum(c => c.TokenCount);
    
    var fileExtension = System.IO.Path.GetExtension(Model.FileName).ToLower().TrimStart('.');
    var iconName = fileExtension switch
    {
        "pdf" => "picture_as_pdf",
        "docx" or "doc" => "description",
        "pptx" or "ppt" => "slideshow",
        "xlsx" or "xls" => "table_chart",
        _ => "text_snippet"
    };
    var iconColorClass = fileExtension switch
    {
        "pdf" => "text-error",
        "docx" or "doc" => "text-primary",
        "pptx" or "ppt" => "text-secondary",
        "xlsx" or "xls" => "text-tertiary",
        _ => "text-outline"
    };
}

<!-- Top controls -->
<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4 select-none">
    @{
        var backUrl = Url.Action("Details", "Subject", new { id = Model.SubjectId });
        var backText = "Quay lại môn học";
        if (User.IsInRole("Admin"))
        {
            backUrl = Url.Action("Documents", "Admin");
            backText = "Quay lại danh sách tài liệu";
        }
    }
    <a href="@backUrl" class="inline-flex items-center gap-1 text-on-surface-variant hover:text-on-surface text-sm transition-colors">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        @backText
    </a>

    <a asp-action="ViewOriginal" asp-route-id="@Model.Id" target="_blank" class="inline-flex items-center gap-2 bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed font-label-md text-label-md px-5 py-2.5 rounded-full transition-all duration-150 font-semibold shadow-sm hover:scale-[1.01]">
        <span class="material-symbols-outlined text-[20px]">download</span>
        Tải xuống file gốc
    </a>
</div>

<!-- Metadata Bento Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8 select-none">
    
    <!-- Doc Title and main metadata (2 cols) -->
    <div class="lg:col-span-2 bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 flex flex-col justify-between">
        <div>
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded bg-surface-container flex items-center justify-center @iconColorClass border border-outline-variant/20">
                    <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">@iconName</span>
                </div>
                <h2 class="font-headline-sm text-headline-sm font-bold text-on-surface truncate max-w-lg" title="@Model.FileName">
                    @Model.FileName
                </h2>
            </div>
            
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-xs font-body-md text-on-surface-variant pt-2">
                <div>
                    <span class="text-outline block mb-0.5">Môn học</span>
                    <strong class="text-on-surface">@Model.SubjectCode - @Model.SubjectName</strong>
                </div>
                <div>
                    <span class="text-outline block mb-0.5">Người tải lên</span>
                    <strong class="text-on-surface">@Model.UploaderName</strong>
                </div>
                <div>
                    <span class="text-outline block mb-0.5">Ngày tải lên</span>
                    <strong class="text-on-surface">@Model.CreatedAt.ToLocalTime().ToString("g")</strong>
                </div>
            </div>
        </div>
    </div>

    <!-- AI Stats Summary (1 col) -->
    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 flex flex-col justify-between">
        <div class="space-y-3">
            <div class="flex justify-between items-center text-xs">
                <span class="text-outline">Trạng thái AI</span>
                @{
                    var statusColorClass = Model.Status switch
                    {
                        DocumentStatus.Success => "bg-tertiary-container/20 border-tertiary/20 text-tertiary",
                        DocumentStatus.Failed => "bg-error-container/20 border-error/20 text-error",
                        DocumentStatus.Processing => "bg-blue-500/10 border-blue-500/20 text-blue-500",
                        _ => "bg-yellow-500/10 border-yellow-500/20 text-yellow-500"
                    };
                }
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold @statusColorClass">
                    @Model.Status.ToString()
                </span>
            </div>
            <div class="flex justify-between items-center text-xs">
                <span class="text-outline">Tổng số Chunks</span>
                <span class="font-semibold text-on-surface">@chunks.Count</span>
            </div>
            <div class="flex justify-between items-center text-xs">
                <span class="text-outline">Tổng lượng Tokens</span>
                <span class="font-semibold text-on-surface">@totalTokens</span>
            </div>
        </div>
    </div>

</div>

<!-- Chunks List Area -->
<div class="space-y-4">
    <div class="flex justify-between items-center select-none border-b border-outline-variant/30 pb-3 mb-6">
        <div>
            <h3 class="font-headline-sm text-headline-sm font-bold text-on-surface">Kết quả phân tích Chunks</h3>
            <p class="text-xs text-on-surface-variant mt-0.5">Nội dung văn bản được trích xuất và mã hóa vector để phục vụ tìm kiếm RAG.</p>
        </div>
        <span class="bg-surface-container border border-outline-variant/50 px-2.5 py-0.5 rounded-full text-xs text-on-surface-variant font-mono">
            @chunks.Count Chunks
        </span>
    </div>

    @if (!chunks.Any())
    {
        <div class="bg-surface-container-low border border-outline-variant border-dashed rounded-2xl p-12 text-center select-none flex flex-col items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center text-outline mb-4 border border-outline-variant animate-pulse">
                <span class="material-symbols-outlined text-[36px]">hourglass_empty</span>
            </div>
            <h5 class="font-headline-sm text-headline-sm text-on-surface mb-1 font-bold">Đang phân tích chunks...</h5>
            <p class="text-on-surface-variant max-w-xs text-xs">Hệ thống đang tiến hành trích xuất dữ liệu. Vui lòng tải lại trang sau vài giây.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var chunk in chunks.OrderBy(c => c.ChunkIndex))
            {
                <div class="bg-surface-container-low border border-outline-variant/50 hover:border-outline-variant transition-colors rounded-xl p-5 shadow-sm overflow-hidden">
                    <!-- Chunk Card Header -->
                    <div class="flex justify-between items-center select-none mb-3">
                        <span class="font-body-md text-sm font-bold text-primary">Chunk #@chunk.ChunkIndex</span>
                        <div class="flex gap-2">
                            <span class="bg-surface border border-outline-variant/50 text-on-surface-variant px-2 py-0.5 rounded text-[10px] font-semibold">
                                Trang @(chunk.PageNumber?.ToString() ?? "N/A")
                            </span>
                            <span class="bg-surface border border-outline-variant/50 text-tertiary px-2 py-0.5 rounded text-[10px] font-semibold">
                                @chunk.TokenCount Tokens
                            </span>
                        </div>
                    </div>
                    
                    <!-- Chunk Card Body -->
                    <div class="bg-surface p-4 border border-outline-variant/30 rounded-lg overflow-x-auto">
                        <p class="font-body-md text-sm text-on-surface-variant leading-relaxed whitespace-pre-wrap break-words">@chunk.Content</p>
                    </div>
                </div>
            }
        </div>
    }
</div>
