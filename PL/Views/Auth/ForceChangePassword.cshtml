@{
    ViewData["Title"] = "Security Check: Change Password";
}

<div class="row justify-content-center py-5">
    <div class="col-md-6 col-lg-5">
        <div class="app-card p-4 shadow">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning p-3 rounded-circle mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-shield-exclamation fs-2"></i>
                </div>
                <h3 class="fw-bold mb-1">First-time Security Check</h3>
                <p class="text-muted small">You are logging in for the first time. Please update your temporary password to activate your account.</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <form asp-action="ForceChangePassword" method="post" id="forceChangeForm">
                @Html.AntiForgeryToken()

                <div class="form-group mb-3">
                    <label for="currentPassword" class="form-label fw-semibold small text-muted">Temporary / Current Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-key"></i></span>
                        <input type="password" id="currentPassword" name="currentPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required />
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="newPassword" class="form-label fw-semibold small text-muted">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" id="newPassword" name="newPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required />
                    </div>
                    <!-- Password Strength Meter -->
                    <div class="pw-strength-bar mt-2">
                        <div class="pw-strength-progress" id="strengthProgress"></div>
                    </div>
                    <span id="strengthText" class="text-muted small mt-1 d-block" style="font-size: 0.75rem;">Password must be at least 6 characters.</span>
                </div>

                <div class="form-group mb-4">
                    <label for="confirmPassword" class="form-label fw-semibold small text-muted">Confirm New Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control border-start-0 ps-0" placeholder="••••••••" required />
                    </div>
                    <span id="matchText" class="text-danger small mt-1 d-block" style="font-size: 0.75rem;"></span>
                </div>

                <div class="d-grid mb-2">
                    <button type="submit" id="submitBtn" class="btn btn-primary justify-content-center py-2.5" disabled>
                        <i class="bi bi-shield-check"></i> Update Password &amp; Login
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const newPassword = document.getElementById('newPassword');
        const confirmPassword = document.getElementById('confirmPassword');
        const strengthProgress = document.getElementById('strengthProgress');
        const strengthText = document.getElementById('strengthText');
        const matchText = document.getElementById('matchText');
        const submitBtn = document.getElementById('submitBtn');

        newPassword.addEventListener('input', validatePassword);
        confirmPassword.addEventListener('input', validatePassword);

        function validatePassword() {
            const val = newPassword.value;
            let score = 0;
            
            if (val.length >= 6) score += 1;
            if (/[a-z]/.test(val) && /[A-Z]/.test(val)) score += 1;
            if (/\d/.test(val)) score += 1;
            if (/[^A-Za-z0-9]/.test(val)) score += 1;

            let progressColor = '#dc2626'; // Red
            let label = 'Weak';
            let width = '25%';

            if (val.length < 6) {
                progressColor = '#dc2626';
                label = 'Too short (min 6 characters)';
                width = '10%';
            } else if (score === 1) {
                progressColor = '#ea580c'; // Orange
                label = 'Weak';
                width = '25%';
            } else if (score === 2) {
                progressColor = '#ca8a04'; // Yellow
                label = 'Fair';
                width = '50%';
            } else if (score === 3) {
                progressColor = '#2563eb'; // Blue
                label = 'Good';
                width = '75%';
            } else if (score >= 4) {
                progressColor = '#16a34a'; // Green
                label = 'Strong';
                width = '100%';
            }

            strengthProgress.style.width = width;
            strengthProgress.style.backgroundColor = progressColor;
            strengthText.textContent = val ? `Strength: ${label}` : 'Password must be at least 6 characters.';
            strengthText.style.color = progressColor;

            // Password match check
            let passwordsMatch = val && val === confirmPassword.value;
            if (confirmPassword.value) {
                if (passwordsMatch) {
                    matchText.textContent = 'Passwords match';
                    matchText.className = 'text-success small mt-1 d-block';
                } else {
                    matchText.textContent = 'Passwords do not match';
                    matchText.className = 'text-danger small mt-1 d-block';
                }
            } else {
                matchText.textContent = '';
            }

            // Enable submit button only if strong enough and matching
            submitBtn.disabled = !(val.length >= 6 && passwordsMatch);
        }
    </script>
}
