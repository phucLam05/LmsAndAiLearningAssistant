    <form asp-action="Login" method="post" class="space-y-4">
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
        
        <div asp-validation-summary="ModelOnly" class="bg-error-container/20 border border-error-container/40 text-error p-3 rounded-xl text-body-md flex items-start gap-2">
            <span class="material-symbols-outlined text-[20px]">error</span>
            <span>Sai thông tin đăng nhập. Vui lòng kiểm tra lại.</span>
        </div>

        <div class="space-y-1">
            <label asp-for="Email" class="block text-label-md font-bold text-on-surface-variant">Địa chỉ Email</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">mail</span>
                <input asp-for="Email" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md" placeholder="name@example.com" />
            </div>
            <span asp-validation-for="Email" class="text-error text-label-md block mt-1"></span>
        </div>

        <div class="space-y-1">
            <label asp-for="Password" class="block text-label-md font-bold text-on-surface-variant">Mật khẩu</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-3.5 text-outline text-[20px]">lock</span>
                <input asp-for="Password" type="password" class="bg-surface-container-low border border-outline-variant/60 rounded-xl pl-10 pr-4 py-3 text-on-surface placeholder:text-outline-variant/60 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full transition-all text-body-md" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Password" class="text-error text-label-md block mt-1"></span>
        </div>

        <button type="submit" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3 px-4 rounded-xl shadow-lg transition-all duration-200 flex items-center justify-center gap-2 hover:scale-[1.01] mt-6">
            <span>Đăng nhập</span>
            <span class="material-symbols-outlined text-[18px]">login</span>
        </button>
    </form>

    <div class="border-t border-outline-variant/30 mt-6 pt-6 text-center text-body-md text-outline">
        Chưa có tài khoản? <a asp-action="Register" class="text-primary hover:underline font-semibold ml-1">Đăng ký ngay</a>
