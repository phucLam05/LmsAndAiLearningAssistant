@model PL.Models.Drive.SearchBarViewModel

<div class="relative @Model.ExtraClasses">
    <input id="@Model.InputId"
           class="w-full bg-surface-container border border-outline-variant text-on-surface font-body-md text-body-md rounded-lg pl-10 pr-4 py-2 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary placeholder:text-on-surface-variant transition-colors"
           placeholder="@Model.Placeholder"
           type="text"
           oninput="@Model.OnInput" />
    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none" style="font-size:18px">search</span>
</div>
