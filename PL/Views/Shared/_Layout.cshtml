<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS AI Learning Assistant</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PL.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var role = isAuthenticated ? (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Student") : "Student";
}
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom app-navbar shadow-sm py-2">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cpu text-primary fs-3"></i>
                    <span>LMS AI</span>
                    <span class="role-badge" id="navRoleBadge">@role</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-md-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-md-center ps-md-4 gap-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-controller="Document" asp-action="Index">My Documents</a>
                        </li>
                        @if (isAuthenticated)
                        {
                            if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-semibold" asp-controller="Admin" asp-action="Users">
                                        <i class="bi bi-people-fill me-1"></i>User Management
                                    </a>
                                </li>
                            }
                            else if (role == "Lecturer")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-semibold" asp-controller="Lecturer" asp-action="Portal">
                                        <i class="bi bi-journal-bookmark-fill me-1"></i>Lecturer Portal
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    
                    <ul class="navbar-nav align-items-center gap-3">
                        @if (isAuthenticated)
                        {
                            <!-- Role Display -->
                            <li class="nav-item d-flex align-items-center gap-2 bg-light px-3 py-1 rounded-pill border">
                                <span class="text-muted small fw-bold text-nowrap mb-0">
                                    <i class="bi bi-shield-lock me-1"></i>Role:
                                </span>
                                <span class="fw-bold text-primary small">@role</span>
                            </li>

                            <li class="nav-item">
                                <span class="text-dark fw-semibold me-2">
                                    <i class="bi bi-person-circle text-secondary me-1"></i>@User.Identity?.Name
                                </span>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                </li>
                            }
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-1.5" style="border-radius:20px;">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary px-4 py-1.5" asp-controller="Auth" asp-action="Register" style="border-radius:20px;">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted bg-white py-3 mt-5">
        <div class="container text-center">
            <span class="small">&copy; 2026 - LMS AI Learning Assistant &bull; NotebookLM Premium Theme</span>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
