@model IEnumerable<Core.Entities.User>
@using Core.Entities
@{
    ViewData["Title"] = "User Management";
}

<style>
    .admin-layout-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 2rem;
    }
    .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
    }
    .status-Active { background: #dcfce7; color: #15803d; }
    .status-Inactive { background: #f1f5f9; color: #475569; }

    .role-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
    }
    .role-Admin { background: #fee2e2; color: #b91c1c; }
    .role-Lecturer { background: #f3e8ff; color: #6b21a8; }
    .role-Student { background: #e0f2fe; color: #0369a1; }

    .user-table {
        width: 100%;
        margin-top: 1rem;
        border-collapse: separate;
        border-spacing: 0 0.5rem;
    }
    .user-table th {
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid #e2e8f0;
    }
    .user-row {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        transition: transform 0.15s ease;
    }
    .user-row td {
        padding: 1rem;
        vertical-align: middle;
        border-top: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
    }
    .user-row td:first-child {
        border-left: 1px solid #e2e8f0;
        border-top-left-radius: 10px;
        border-bottom-left-radius: 10px;
    }
    .user-row td:last-child {
        border-right: 1px solid #e2e8f0;
        border-top-right-radius: 10px;
        border-bottom-right-radius: 10px;
    }
    .excel-import-box {
        border: 2px dashed #cbd5e1;
        background: #f8fafc;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .excel-import-box:hover {
        border-color: #4f46e5;
        background: #f1f5f9;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold" style="color: #0f172a;">User Management</h1>
            <p class="text-muted">Manage system identity, edit account roles, and import students bulk from Excel lists.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">Dashboard</a>
            <a asp-action="CreateUser" class="btn btn-primary" style="background-color: #4f46e5; border-color: #4f46e5;">+ Create User</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show document-alert mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show document-alert mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="admin-layout-grid">
        <!-- Left Side: User Table -->
        <div>
            <div class="table-responsive">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>User Code</th>
                            <th>Full Name</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="user-row">
                                <td class="fw-bold text-secondary" style="font-family: monospace;">@user.UserCode</td>
                                <td class="fw-bold text-dark">@user.FullName</td>
                                <td>
                                    <span class="role-badge role-@user.Role.ToString()">
                                        @user.Role.ToString()
                                    </span>
                                </td>
                                <td>
                                    <span class="status-badge status-@user.Status.ToString()">
                                        @(user.Status == UserStatus.Active ? "Active" : "Inactive / Pending")
                                    </span>
                                </td>
                                <td class="text-muted" style="font-size: 0.875rem;">@user.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary py-1 px-2.5">
                                            Edit
                                        </a>
                                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this user? All subject associations and uploaded documents will be lost.');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2.5">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Right Side: Excel Import Card -->
        <div>
            <div class="card shadow-sm border-0" style="border-radius: 12px; position: sticky; top: 1.5rem;">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3" style="color: #1e293b;">Bulk Upload Students</h4>
                    <p class="text-muted small mb-4">
                        Upload an Excel file (.xlsx) containing student accounts.
                        The file must contain:
                        <br />• <strong>Column A</strong>: Full Name
                        <br />• <strong>Column B</strong>: Email Address
                    </p>

                    <form asp-action="ImportStudents" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <label class="excel-import-box w-100" id="dropzone" for="excelFile">
                            <svg class="mx-auto mb-2 text-secondary" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="8" x2="8" y2="8"></line>
                                <line x1="16" y1="12" x2="8" y2="12"></line>
                                <line x1="16" y1="16" x2="8" y2="16"></line>
                            </svg>
                            <span class="d-block fw-semibold" style="color: #475569;" id="upload-label">Choose Excel list</span>
                            <input id="excelFile" name="excelFile" type="file" class="d-none" accept=".xlsx" required />
                        </label>

                        <div id="file-info" class="mt-3 p-2 bg-light border rounded text-truncate" style="display: none; font-size: 0.85rem;">
                            Selected: <strong id="file-name-text"></strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-4 py-2 fw-semibold" style="border-radius: 8px; background: #4f46e5; border-color: #4f46e5;">
                            Import Students
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const excelFileInput = document.getElementById('excelFile');
        const fileInfo = document.getElementById('file-info');
        const fileNameText = document.getElementById('file-name-text');
        const uploadLabel = document.getElementById('upload-label');

        excelFileInput.addEventListener('change', () => {
            const file = excelFileInput.files?.[0];
            if (file) {
                fileInfo.style.display = 'block';
                fileNameText.textContent = file.name;
                uploadLabel.textContent = 'Change file';
            } else {
                fileInfo.style.display = 'none';
                uploadLabel.textContent = 'Choose Excel list';
            }
        });
    </script>
}
