@model List<PL.Controllers.AdminController.MockUser>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}



<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div class="select-none">
        <span class="bg-primary/10 text-primary border border-primary/20 px-2.5 py-0.5 rounded-lg text-xs font-mono font-bold tracking-tight">
            Admin Console
        </span>
        <h1 class="font-headline-lg text-headline-lg md:font-display-lg md:text-display-lg font-bold text-on-surface mt-2 tracking-tight">Quản lý Người dùng</h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant mt-1 font-medium">Tạo lập tài khoản học viên, giảng viên và tải lên tệp tin danh sách hàng loạt.</p>
    </div>
    
    <button type="button" onclick="openModal('addUserModal')" class="bg-primary text-on-primary font-label-md text-label-md px-5 py-2.5 rounded-full hover:bg-primary-fixed hover:text-on-primary-fixed transition-all duration-200 flex items-center gap-2 font-medium shadow-sm hover:scale-[1.02]">
        <span class="material-symbols-outlined text-[20px]">person_add</span>
        Thêm người dùng mới
    </button>
</div>

<!-- Main Workspace Layout Grid -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Left Panel: User CRUD Table (2 cols) -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 shadow-sm">
            <!-- Filter toolbar -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-5 border-b border-outline-variant/30 pb-4 select-none">
                <h3 class="font-headline-sm text-headline-sm font-bold text-on-surface">Danh sách tài khoản</h3>
                
                <form asp-action="Users" method="get" class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
                    <div class="relative w-full sm:w-[220px]">
                        <span class="material-symbols-outlined absolute left-2.5 top-2.5 text-outline text-[18px]">search</span>
                        <input type="text" name="search" class="bg-surface border border-outline-variant/50 rounded-lg pl-9 pr-3 py-1.5 text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" placeholder="Tìm kiếm họ tên, email..." value="@ViewBag.Search" />
                    </div>
                    
                    <select name="role" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-1.5 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-xs cursor-pointer" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Role) ? "selected" : null)">Tất cả vai trò</option>
                        <option value="Admin" selected="@(ViewBag.Role == "Admin" ? "selected" : null)">Quản trị viên</option>
                        <option value="Lecturer" selected="@(ViewBag.Role == "Lecturer" ? "selected" : null)">Giảng viên</option>
                        <option value="Student" selected="@(ViewBag.Role == "Student" ? "selected" : null)">Sinh viên</option>
                    </select>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Role))
                    {
                        <a asp-action="Users" class="p-1.5 bg-surface border border-outline-variant/50 hover:bg-surface-container-high rounded-lg text-on-surface transition-colors" title="Xóa bộ lọc">
                            <span class="material-symbols-outlined text-[18px] block">close</span>
                        </a>
                    }
                </form>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-lowest border-b border-outline-variant/50 select-none">
                            <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Thông tin người dùng</th>
                            <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Mã số (User Code)</th>
                            <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Vai trò</th>
                            <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                            <th class="p-4 font-label-md text-label-md font-semibold text-on-surface-variant w-24"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/30">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-12 text-on-surface-variant select-none">
                                    <span class="material-symbols-outlined text-[48px] text-outline mb-2">group_off</span>
                                    <h5 class="font-headline-sm text-sm font-bold">Không tìm thấy người dùng</h5>
                                    <p class="text-xs text-outline max-w-sm mx-auto mt-1">Không có tài khoản nào phù hợp với bộ lọc tìm kiếm của bạn.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model)
                            {
                                var roleBadgeClass = user.Role switch
                                {
                                    "Admin" => "bg-error-container/20 border-error/20 text-error",
                                    "Lecturer" => "bg-blue-500/10 border-blue-500/20 text-blue-500",
                                    _ => "bg-tertiary-container/20 border-tertiary/20 text-tertiary"
                                };

                                var statusBadgeClass = user.Status == "Active" ? "bg-tertiary-container/20 border-tertiary/20 text-tertiary" : "bg-yellow-500/10 border-yellow-500/20 text-yellow-500";

                                <tr class="hover:bg-surface-container/30 transition-colors group">
                                    <td class="p-4">
                                        <div>
                                            <div class="font-body-md text-sm font-bold text-on-surface">@user.FullName</div>
                                            <div class="text-xs text-outline font-medium">@user.Email</div>
                                        </div>
                                    </td>
                                    <td class="p-4 font-mono text-xs text-on-surface-variant select-all">
                                        @(string.IsNullOrEmpty(user.StudentCode) ? "N/A" : user.StudentCode)
                                    </td>
                                    <td class="p-4 select-none">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded border text-[10px] font-bold tracking-wide @roleBadgeClass">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td class="p-4 select-none">
                                        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border text-[10px] font-bold @statusBadgeClass">
                                            <span class="w-1.5 h-1.5 rounded-full @(user.Status == "Active" ? "bg-tertiary animate-pulse" : "bg-yellow-500")"></span>
                                            @user.Status
                                        </span>
                                    </td>
                                    <td class="p-4">
                                        <div class="flex justify-end gap-2 items-center opacity-0 group-hover:opacity-100 transition-opacity">
                                            <button type="button" onclick="prepareEditModal('@user.Id', '@user.FullName', '@user.Email', '@user.Role', '@user.StudentCode', '@user.Status')" class="p-1.5 bg-surface border border-outline-variant hover:bg-surface-container-high rounded text-on-surface transition-colors" title="Sửa thông tin">
                                                <span class="material-symbols-outlined text-[16px] block">edit</span>
                                            </button>
                                            @if (user.Email != User.Identity?.Name)
                                            {
                                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="inline" data-confirm="Bạn có chắc chắn muốn xóa tài khoản @user.FullName?">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="p-1.5 bg-surface border border-outline-variant hover:bg-error-container/20 rounded text-error transition-colors" title="Xóa tài khoản">
                                                        <span class="material-symbols-outlined text-[16px] block">delete</span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Panel: Excel Importer (1 col) -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-5 sticky top-6">
            <div class="flex justify-between items-center mb-3 border-b border-outline-variant/30 pb-3 select-none">
                <h4 class="font-headline-sm text-base font-bold text-on-surface">Nhập danh sách</h4>
                <button class="text-tertiary hover:text-tertiary-fixed-dim transition-colors flex items-center gap-1 text-[11px] font-semibold" onclick="downloadSampleExcel()">
                    <span class="material-symbols-outlined text-[16px]">download</span> Template
                </button>
            </div>

            <p class="font-body-md text-xs text-on-surface-variant mb-4 select-none">Nhập học viên hàng loạt từ tệp Excel. Tài khoản mới sẽ buộc phải đặt lại mật khẩu ở lần đăng nhập đầu tiên.</p>
            
            <!-- Excel Drag & Drop Zone -->
            <div class="border-2 border-dashed border-outline-variant hover:border-primary/50 hover:bg-surface-container/40 transition-all rounded-xl p-6 text-center cursor-pointer flex flex-col items-center justify-center select-none mb-4" id="excelDropzone">
                <span class="material-symbols-outlined text-[40px] text-outline mb-1.5">upload_file</span>
                <h6 class="font-label-md text-label-md text-on-surface font-semibold">Kéo thả tệp tin Excel sinh viên</h6>
                <p class="text-[10px] text-outline mt-0.5">Chỉ hỗ trợ định dạng .xlsx hoặc .xls</p>
                <input type="file" id="excelFile" accept=".xlsx, .xls" class="hidden" />
            </div>

            <!-- Selected Excel Status Card -->
            <div id="selectedExcelCard" class="bg-surface-container border border-tertiary/20 p-3 rounded-xl flex items-center justify-between select-none hidden">
                <div class="flex items-center gap-2.5 min-w-0">
                    <span class="material-symbols-outlined text-[24px] text-tertiary filled">table_chart</span>
                    <div class="min-w-0">
                        <strong id="excelFileName" class="text-on-surface text-xs font-semibold block truncate max-w-[150px]">student_list.xlsx</strong>
                        <span id="excelFileSize" class="text-[10px] text-outline block">12.4 KB</span>
                    </div>
                </div>
                <button type="button" class="text-on-surface-variant hover:text-on-surface p-1 rounded" onclick="resetExcelImport()">
                    <span class="material-symbols-outlined text-[18px] block">close</span>
                </button>
            </div>

            <!-- Import Progress Section -->
            <div id="importProgressSection" class="hidden space-y-1.5 my-3 select-none">
                <div class="flex justify-between items-center text-xs">
                    <span class="text-primary font-semibold" id="progressStatusText">Đang phân tích tệp...</span>
                    <span class="font-mono" id="progressPercent">0%</span>
                </div>
                <div class="w-full bg-surface-container-high rounded-full h-1.5 overflow-hidden">
                    <div class="bg-primary h-1.5 rounded-full transition-all duration-200" id="importProgressBar" style="width: 0%"></div>
                </div>
            </div>

            <!-- Import Results Feedback Section -->
            <div id="importResultsSection" class="hidden space-y-3 pt-3 border-t border-outline-variant/30">
                <div class="flex justify-between items-center select-none">
                    <h6 class="font-label-md text-xs font-bold text-on-surface">Kết quả phân tích hàng loạt</h6>
                    <span class="bg-tertiary-container/20 border border-tertiary/20 px-2 py-0.5 rounded text-[10px] font-bold text-tertiary" id="importSummaryBadge">0 Succeeded</span>
                </div>
                <div id="importResultsList" class="max-h-[180px] overflow-y-auto space-y-2 pr-1">
                    <!-- Dynamically populated rows -->
                </div>
                <button type="button" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-2.5 px-4 rounded-xl shadow-md transition-all duration-200 flex items-center justify-center gap-2 text-xs font-semibold hover:scale-[1.01]" onclick="saveImportResults()" id="btnSaveImport" disabled>
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    Lưu danh sách tài khoản hợp lệ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Overlay: Add User (Tailwind/JS) -->
<div id="addUserModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 hidden select-none animate-fade-in">
    <div class="bg-surface-container-low border border-outline-variant/40 rounded-2xl w-full max-w-[440px] overflow-hidden shadow-2xl">
        <form asp-action="CreateUser" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center">
                <h5 class="font-headline-sm text-base font-bold text-on-surface">Tạo tài khoản mới</h5>
                <button type="button" onclick="closeModal('addUserModal')" class="text-on-surface-variant hover:text-on-surface">
                    <span class="material-symbols-outlined text-[20px] block">close</span>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div class="space-y-1">
                    <label for="createFullName" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Họ và tên</label>
                    <input type="text" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="createFullName" name="fullName" placeholder="e.g. John Doe" required />
                </div>
                <div class="space-y-1">
                    <label for="createEmail" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Địa chỉ Email</label>
                    <input type="email" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="createEmail" name="email" placeholder="e.g. john.doe@lmsai.com" required />
                </div>
                <div class="space-y-1">
                    <label for="createRole" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Vai trò tài khoản</label>
                    <select class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="createRole" name="role" onchange="toggleStudentCodeField(this, 'createCodeContainer')">
                        <option value="Student">Sinh viên</option>
                        <option value="Lecturer">Giảng viên</option>
                        <option value="Admin">Quản trị viên</option>
                    </select>
                </div>
                <div class="space-y-1" id="createCodeContainer">
                    <label for="createStudentCode" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Mã số (User Code)</label>
                    <input type="text" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface placeholder:text-outline/40 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="createStudentCode" name="studentCode" placeholder="e.g. HE170123" />
                </div>
                <label class="flex items-center gap-2 pt-2 cursor-pointer select-none">
                    <input type="checkbox" class="rounded border-outline-variant bg-surface text-primary focus:ring-primary w-4 h-4" id="createMustChange" name="mustChangePassword" value="true" checked />
                    <span class="text-xs text-on-surface-variant">Buộc đặt lại mật khẩu ở lần đăng nhập đầu tiên</span>
                </label>
            </div>
            <div class="px-6 py-4 border-t border-outline-variant/30 flex justify-end gap-2">
                <button type="button" onclick="closeModal('addUserModal')" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-4 py-2 rounded-lg font-label-md text-xs transition-colors">Hủy</button>
                <button type="submit" class="bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed px-4 py-2 rounded-lg font-label-md text-xs font-semibold transition-colors">Tạo người dùng</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Overlay: Edit User (Tailwind/JS) -->
<div id="editUserModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 hidden select-none animate-fade-in">
    <div class="bg-surface-container-low border border-outline-variant/40 rounded-2xl w-full max-w-[440px] overflow-hidden shadow-2xl">
        <form asp-action="EditUser" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editUserId" name="id" />
            <div class="px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center">
                <h5 class="font-headline-sm text-base font-bold text-on-surface">Chỉnh sửa tài khoản</h5>
                <button type="button" onclick="closeModal('editUserModal')" class="text-on-surface-variant hover:text-on-surface">
                    <span class="material-symbols-outlined text-[20px] block">close</span>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div class="space-y-1">
                    <label for="editFullName" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Họ và tên</label>
                    <input type="text" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="editFullName" name="fullName" required />
                </div>
                <div class="space-y-1">
                    <label for="editEmail" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Địa chỉ Email</label>
                    <input type="email" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="editEmail" name="email" required readonly />
                </div>
                <div class="space-y-1">
                    <label for="editRole" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Vai trò tài khoản</label>
                    <select class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="editRole" name="role" onchange="toggleStudentCodeField(this, 'editCodeContainer')">
                        <option value="Student">Sinh viên</option>
                        <option value="Lecturer">Giảng viên</option>
                        <option value="Admin">Quản trị viên</option>
                    </select>
                </div>
                <div class="space-y-1" id="editCodeContainer">
                    <label for="editStudentCode" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Mã số (User Code)</label>
                    <input type="text" class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="editStudentCode" name="studentCode" />
                </div>
                <div class="space-y-1">
                    <label for="editStatus" class="block text-label-md font-bold text-on-surface-variant text-[11px]">Trạng thái</label>
                    <select class="bg-surface border border-outline-variant/50 rounded-lg px-3 py-2 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs" id="editStatus" name="status">
                        <option value="Active">Hoạt động</option>
                        <option value="Inactive">Tạm khóa</option>
                    </select>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-outline-variant/30 flex justify-end gap-2">
                <button type="button" onclick="closeModal('editUserModal')" class="bg-surface border border-outline-variant hover:bg-surface-container-high text-on-surface px-4 py-2 rounded-lg font-label-md text-xs transition-colors">Hủy</button>
                <button type="submit" class="bg-primary text-on-primary hover:bg-primary-fixed hover:text-on-primary-fixed px-4 py-2 rounded-lg font-label-md text-xs font-semibold transition-colors">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <!-- Include SheetJS CDN to parse Excel directly on the client-side for smooth UX -->
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script>
        // Modal Control Helpers
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        function prepareEditModal(id, name, email, role, code, status) {
            document.getElementById('editUserId').value = id;
            document.getElementById('editFullName').value = name;
            document.getElementById('editEmail').value = email;
            
            const roleSelect = document.getElementById('editRole');
            roleSelect.value = role;
            toggleStudentCodeField(roleSelect, 'editCodeContainer');

            document.getElementById('editStudentCode').value = code || '';
            document.getElementById('editStatus').value = status;
            
            openModal('editUserModal');
        }

        function toggleStudentCodeField(selectElem, containerId) {
            const container = document.getElementById(containerId);
            if (selectElem.value === 'Student') {
                container.style.display = 'block';
            } else {
                container.style.display = 'none';
            }
        }

        // Excel Import Drag and Drop
        const dropzone = document.getElementById('excelDropzone');
        const fileInput = document.getElementById('excelFile');
        let parsedUsersList = [];

        dropzone?.addEventListener('click', () => fileInput.click());
        dropzone?.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('border-primary/50', 'bg-surface-container/40');
        });
        dropzone?.addEventListener('dragleave', () => {
            dropzone.classList.remove('border-primary/50', 'bg-surface-container/40');
        });
        dropzone?.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('border-primary/50', 'bg-surface-container/40');
            const files = e.dataTransfer.files;
            if (files.length) handleExcelFile(files[0]);
        });

        fileInput?.addEventListener('change', (e) => {
            const files = e.target.files;
            if (files.length) handleExcelFile(files[0]);
        });

        function handleExcelFile(file) {
            const validTypes = ['.xlsx', '.xls'];
            const fileExtension = file.name.slice(file.name.lastIndexOf('.')).toLowerCase();
            
            if (!validTypes.includes(fileExtension)) {
                showNotification('Vui lòng chỉ tải lên tệp tin Excel (.xlsx hoặc .xls)', 'warning');
                return;
            }

            // Display file details
            document.getElementById('excelFileName').textContent = file.name;
            document.getElementById('excelFileSize').textContent = `${(file.size / 1024).toFixed(1)} KB`;
            
            const excelCard = document.getElementById('selectedExcelCard');
            excelCard.classList.remove('hidden');
            excelCard.classList.add('flex');
            dropzone.classList.add('hidden');

            parseExcelData(file);
        }

        function parseExcelData(file) {
            const progressSection = document.getElementById('importProgressSection');
            const progressBar = document.getElementById('importProgressBar');
            const progressStatusText = document.getElementById('progressStatusText');
            const progressPercent = document.getElementById('progressPercent');

            progressSection.classList.remove('hidden');
            progressBar.style.width = '0%';
            progressStatusText.textContent = 'Đang đọc tệp tin Excel...';
            progressPercent.textContent = '0%';

            const reader = new FileReader();
            
            setTimeout(() => {
                reader.onload = function(e) {
                    progressBar.style.width = '50%';
                    progressPercent.textContent = '50%';
                    progressStatusText.textContent = 'Đang trích xuất dữ liệu dòng...';

                    setTimeout(() => {
                        try {
                            const data = new Uint8Array(e.target.result);
                            const workbook = XLSX.read(data, { type: 'array' });
                            const firstSheetName = workbook.SheetNames[0];
                            const worksheet = workbook.Sheets[firstSheetName];
                            
                            const rawRows = XLSX.utils.sheet_to_json(worksheet);
                            
                            progressBar.style.width = '90%';
                            progressPercent.textContent = '90%';
                            progressStatusText.textContent = 'Đang kiểm tra định dạng...';

                            setTimeout(() => {
                                progressBar.style.width = '100%';
                                progressPercent.textContent = '100%';
                                progressStatusText.textContent = 'Phân tích hoàn tất!';
                                
                                processImportedRows(rawRows);
                            }, 400);

                        } catch (err) {
                            showNotification('Lỗi phân tích Excel: ' + err.message, 'error');
                            resetExcelImport();
                        }
                    }, 400);
                };
                reader.readAsArrayBuffer(file);
            }, 300);
        }

        function processImportedRows(rawRows) {
            const resultsSection = document.getElementById('importResultsSection');
            const resultsList = document.getElementById('importResultsList');
            const summaryBadge = document.getElementById('importSummaryBadge');
            const btnSave = document.getElementById('btnSaveImport');

            resultsList.innerHTML = '';
            parsedUsersList = [];
            
            if (!rawRows || rawRows.length === 0) {
                resultsList.innerHTML = '<div class="text-center text-on-surface-variant text-xs py-4">Tệp Excel trống hoặc không đúng định dạng.</div>';
                summaryBadge.textContent = '0 học viên';
                summaryBadge.className = 'bg-error-container/20 border border-error/20 px-2 py-0.5 rounded text-[10px] font-bold text-error';
                btnSave.disabled = true;
                resultsSection.classList.remove('hidden');
                return;
            }

            let successCount = 0;
            let failCount = 0;

            rawRows.forEach((row, index) => {
                const fullName = row.FullName || row['Full Name'] || row['Name'] || '';
                const email = row.Email || row['Email Address'] || '';
                const code = row.StudentCode || row['Student Code'] || row['Code'] || '';
                
                let isSucceeded = true;
                let failReason = '';

                if (!fullName || !email) {
                    isSucceeded = false;
                    failReason = 'Thiếu Tên hoặc Email';
                } else if (!email.includes('@@')) {
                    isSucceeded = false;
                    failReason = 'Email sai định dạng';
                }

                const card = document.createElement('div');
                card.className = 'border p-3 rounded-xl flex items-center justify-between text-xs transition-all duration-150';
                
                if (isSucceeded) {
                    successCount++;
                    card.classList.add('bg-tertiary-container/10', 'border-tertiary/20');
                    card.innerHTML = `
                        <div>
                            <div class="font-bold text-on-surface">${fullName}</div>
                            <div class="text-[10px] text-outline">${email} &bull; Mã: ${code || 'Auto-generate'}</div>
                        </div>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[9px] font-bold bg-tertiary-container/20 border-tertiary/20 text-tertiary">
                            Hợp lệ
                        </span>
                    `;
                    parsedUsersList.push({ fullName, email, studentCode: code });
                } else {
                    failCount++;
                    card.classList.add('bg-error-container/10', 'border-error/20');
                    card.innerHTML = `
                        <div>
                            <div class="font-bold text-on-surface">${fullName || 'Dòng ' + (index + 1)}</div>
                            <div class="text-[10px] text-error font-medium">${failReason}</div>
                        </div>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border text-[9px] font-bold bg-error-container/20 border-error/20 text-error">
                            Lỗi
                        </span>
                    `;
                }
                resultsList.appendChild(card);
            });

            summaryBadge.textContent = `${successCount} hợp lệ, ${failCount} lỗi`;
            if (failCount > 0) {
                summaryBadge.className = 'bg-error-container/20 border border-error/20 px-2 py-0.5 rounded text-[10px] font-bold text-error';
            } else {
                summaryBadge.className = 'bg-tertiary-container/20 border border-tertiary/20 px-2 py-0.5 rounded text-[10px] font-bold text-tertiary';
            }

            btnSave.disabled = parsedUsersList.length === 0;
            resultsSection.classList.remove('hidden');
        }

        function resetExcelImport() {
            const excelCard = document.getElementById('selectedExcelCard');
            excelCard.classList.add('hidden');
            excelCard.classList.remove('flex');
            dropzone.classList.remove('hidden');
            fileInput.value = '';
            document.getElementById('importProgressSection').classList.add('hidden');
            document.getElementById('importResultsSection').classList.add('hidden');
            parsedUsersList = [];
        }

        function saveImportResults() {
            if (!parsedUsersList.length) return;

            const btnSave = document.getElementById('btnSaveImport');
            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="w-3.5 h-3.5 border-2 border-t-transparent border-on-primary rounded-full animate-spin"></span> Đang lưu tài khoản...';

            fetch('/Admin/BulkImport', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(parsedUsersList)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification(`Import hoàn tất! Đã thêm thành công ${data.successCount} tài khoản học sinh.`, 'success');
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showNotification('Lỗi khi lưu dữ liệu: ' + data.message, 'error');
                    btnSave.disabled = false;
                    btnSave.innerHTML = '<span class="material-symbols-outlined text-[18px]">check_circle</span> Lưu danh sách tài khoản hợp lệ';
                }
            })
            .catch(err => {
                showNotification('Không thể kết nối đến máy chủ.', 'error');
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            });
        }

        function downloadSampleExcel() {
            const headers = 'FullName,Email,StudentCode\n';
            const rows = [
                'Nguyen Van A,anv.student@lms-ai.edu.vn,HE170123',
                'Tran Thi B,btt.student@lms-ai.edu.vn,HE170456',
                'Le Hung Cuong,cuonglh.student@lms-ai.edu.vn,HE170789'
            ].join('\n');
            
            const csvContent = "data:text/csv;charset=utf-8," + encodeURIComponent(headers + rows);
            const downloadAnchor = document.createElement('a');
            downloadAnchor.setAttribute("href", csvContent);
            downloadAnchor.setAttribute("download", "sample_student_list.csv");
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            document.body.removeChild(downloadAnchor);
        }
    </script>
}
