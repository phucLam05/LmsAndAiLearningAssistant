@model Core.DTOs.Admin.DashboardStatsDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card text-white bg-primary h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <h2 class="display-5 fw-bold">@Model.TotalUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Documents Uploaded</h5>
                    <h2 class="display-5 fw-bold">@Model.TotalDocuments</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Storage Used (MB)</h5>
                    <h2 class="display-5 fw-bold">@(Math.Round((double)Model.TotalStorageUsedBytes / 1024 / 1024, 2))</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info h-100 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Total AI Chunks</h5>
                    <h2 class="display-5 fw-bold">@Model.TotalDocumentChunks</h2>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3" style="color: #0f172a;">Quick Actions</h4>
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #1e293b;">Manage Users</h5>
                    <p class="card-text text-muted small">Create, edit, delete user accounts or upload student lists bulk from Excel.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="Users" class="btn btn-sm btn-primary py-2 px-3 fw-semibold" style="background-color: #4f46e5; border-color: #4f46e5; border-radius: 8px;">
                            Open User Manager &rarr;
                        </a>
                        <a asp-action="CreateUser" class="btn btn-sm btn-outline-primary py-2 px-3 fw-semibold" style="border-radius: 8px;">
                            + Create User
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #1e293b;">Manage Subjects</h5>
                    <p class="card-text text-muted small">Register new subjects, write course details, and assign lecturer accounts.</p>
                    <a asp-controller="Subject" asp-action="Index" class="btn btn-sm btn-primary py-2 px-3 fw-semibold" style="background-color: #4f46e5; border-color: #4f46e5; border-radius: 8px;">
                        Open Subject Manager &rarr;
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #1e293b;">Background Jobs</h5>
                    <p class="card-text text-muted small">Monitor document chunking status, vector embedding generation, and Hangfire schedules.</p>
                    <a href="/hangfire" target="_blank" class="btn btn-sm btn-outline-secondary py-2 px-3 fw-semibold" style="border-radius: 8px;">
                        Open Dashboard &rarr;
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- System Resources Chart -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                <div class="card-header bg-white fw-bold border-0 pt-3" style="color: #0f172a;">
                    System Resources Overview
                </div>
                <div class="card-body d-flex align-items-center" style="min-height: 380px;">
                    <canvas id="resourcesChart" style="max-height: 340px; width: 100%;"></canvas>
                </div>
            </div>
        </div>
        
        <!-- Quick Account Creation Form -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 12px;">
                <div class="card-header bg-white fw-bold border-0 pt-3" style="color: #0f172a;">
                    Quick Account Creation
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Create and automatically notify a new student, lecturer, or admin account.</p>
                    
                    <form asp-controller="Admin" asp-action="CreateUser" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label for="FullName" class="form-label fw-semibold text-secondary small mb-1">Full Name</label>
                            <input type="text" id="FullName" name="FullName" class="form-control form-control-sm" placeholder="e.g., John Doe" required style="border-radius: 8px;" />
                        </div>
                        
                        <div class="mb-3">
                            <label for="Email" class="form-label fw-semibold text-secondary small mb-1">Email Address</label>
                            <input type="email" id="Email" name="Email" class="form-control form-control-sm" placeholder="e.g., john@lmsai.com" required style="border-radius: 8px;" />
                        </div>
                        
                        <div class="mb-3">
                            <label for="UserCode" class="form-label fw-semibold text-secondary small mb-1">User Code (ID)</label>
                            <input type="text" id="UserCode" name="UserCode" class="form-control form-control-sm" placeholder="e.g., STU12345" required style="border-radius: 8px;" />
                        </div>
                        
                        <div class="mb-3">
                            <label for="Role" class="form-label fw-semibold text-secondary small mb-1">Role</label>
                            <select id="Role" name="Role" class="form-select form-select-sm" required style="border-radius: 8px;">
                                <option value="2">Student</option>
                                <option value="1">Lecturer</option>
                                <option value="0">Admin</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-sm btn-primary w-100 py-2 fw-semibold mt-2" style="background-color: #4f46e5; border-color: #4f46e5; border-radius: 8px;">
                            Create & Send Notification
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var ctx = document.getElementById('resourcesChart').getContext('2d');
            var resourcesChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Users', 'Documents', 'Chunks'],
                    datasets: [{
                        label: 'Count',
                        data: [@Model.TotalUsers, @Model.TotalDocuments, @Model.TotalDocumentChunks],
                        backgroundColor: [
                            'rgba(13, 110, 253, 0.7)',
                            'rgba(25, 135, 84, 0.7)',
                            'rgba(13, 202, 240, 0.7)'
                        ],
                        borderColor: [
                            'rgba(13, 110, 253, 1)',
                            'rgba(25, 135, 84, 1)',
                            'rgba(13, 202, 240, 1)'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}
