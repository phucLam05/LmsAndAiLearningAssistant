@model Core.DTOs.Admin.UserCreateDto
@using Core.Entities
@{
    ViewData["Title"] = "Tạo tài khoản";
}

<div class="max-w-xl mx-auto space-y-6 select-none animate-fade-in">
    <div>
        <a asp-action="Users" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high px-4 py-2 rounded-lg transition-colors text-xs font-semibold border border-outline-variant/30">
            <span class="material-symbols-outlined text-[16px]">arrow_back</span>
            Quay lại danh sách
        </a>
    </div>

    <div class="bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 md:p-8 shadow-xl">
        <h2 class="font-headline-md text-headline-md font-bold text-on-surface mb-2">Tạo người dùng mới</h2>
        <p class="font-body-md text-xs text-on-surface-variant mb-6 leading-relaxed">Đăng ký thủ công tài khoản giảng viên, sinh viên hoặc quản trị viên mới trên hệ thống.</p>

        <form asp-action="CreateUser" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="bg-error-container/20 border border-error-container/30 text-error p-3 rounded-xl text-xs flex items-start gap-2 mb-4">
                <span class="material-symbols-outlined text-[18px]">error</span>
                <span>Vui lòng kiểm tra lại thông tin nhập vào.</span>
            </div>

            <div class="space-y-1">
                <label asp-for="FullName" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Họ và tên</label>
                <input asp-for="FullName" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. Nguyễn Văn A" required />
                <span asp-validation-for="FullName" class="text-error text-[10px] block mt-1"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Email" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Địa chỉ Email</label>
                <input asp-for="Email" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. anv@lmsai.com" required />
                <span asp-validation-for="Email" class="text-error text-[10px] block mt-1"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="UserCode" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Mã định danh (User Code / ID)</label>
                <input asp-for="UserCode" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface placeholder:text-outline-variant/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" placeholder="e.g. HE170123 hoặc LEC001" required />
                <span class="text-[10px] text-outline block">Mã số sinh viên (MSSV) hoặc mã giảng viên duy nhất.</span>
                <span asp-validation-for="UserCode" class="text-error text-[10px] block mt-1"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Role" class="block text-label-md font-bold text-on-surface-variant text-[11px] uppercase tracking-wider">Vai trò</label>
                <select asp-for="Role" class="bg-surface-container-lowest border border-outline-variant/60 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary w-full text-xs transition-all" required>
                    <option value="@UserRole.Student">Sinh viên (Student)</option>
                    <option value="@UserRole.Lecturer">Giảng viên (Lecturer)</option>
                    <option value="@UserRole.Admin">Quản trị viên (Admin)</option>
                </select>
                <span asp-validation-for="Role" class="text-error text-[10px] block mt-1"></span>
            </div>

            <button type="submit" class="w-full bg-primary hover:bg-primary/95 text-on-primary font-bold py-3.5 px-4 rounded-xl shadow-md transition-all duration-200 flex items-center justify-center gap-2 text-xs font-semibold hover:scale-[1.01] mt-6">
                <span>Tạo tài khoản &amp; Gửi thông báo</span>
                <span class="material-symbols-outlined text-[16px]">person_add</span>
            </button>
        </form>
    </div>
</div>

