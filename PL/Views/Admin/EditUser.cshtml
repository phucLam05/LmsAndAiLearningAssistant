@model Core.DTOs.Admin.UserEditDto
@using Core.Entities
@{
    ViewData["Title"] = "Edit User";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Users" class="btn btn-sm btn-outline-secondary">&larr; Back to Users</a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 16px;">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-2" style="color: #1a1f36;">Edit User</h2>
            <p class="text-muted mb-4">Modify user account details, role, or active status.</p>

            <form asp-action="EditUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="e.g., John Doe" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label fw-semibold">Role</label>
                    <select asp-for="Role" class="form-select" required>
                        <option value="@UserRole.Student">Student</option>
                        <option value="@UserRole.Lecturer">Lecturer</option>
                        <option value="@UserRole.Admin">Admin</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select" required>
                        <option value="@UserStatus.Active">Active</option>
                        <option value="@UserStatus.Inactive">Inactive / Pending Activation</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2.5 fw-semibold" style="border-radius: 10px; background-color: #4f46e5; border-color: #4f46e5;">
                    Save Changes
                </button>
            </form>
        </div>
    </div>
</div>
